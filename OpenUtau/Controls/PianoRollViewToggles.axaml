<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:OpenUtau.App.Controls"
             x:Class="OpenUtau.App.Controls.PianoRollViewToggles">
  <UserControl.Styles>
    <!-- Exclusive to this side-toolbar bar — must NOT use Classes="overlay"
         or global ScrollBar.overlay:vertical /template/ Thumb (8px / 0.85) wins. -->
    <Style Selector="ScrollBar.sideToolbarOverlay">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="ClipToBounds" Value="False"/>
      <Setter Property="AllowAutoHide" Value="False"/>
      <Setter Property="MinWidth" Value="10"/>
      <Setter Property="MaxWidth" Value="10"/>
      <Setter Property="Width" Value="10"/>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ Rectangle#TrackRect">
      <Setter Property="Fill" Value="Transparent"/>
      <Setter Property="Stroke" Value="Transparent"/>
      <Setter Property="Opacity" Value="0"/>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ RepeatButton#PART_LineUpButton,
                   ScrollBar.sideToolbarOverlay /template/ RepeatButton#PART_LineDownButton">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="IsHitTestVisible" Value="False"/>
      <Setter Property="Width" Value="0"/>
      <Setter Property="Height" Value="0"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Opacity" Value="0"/>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ RepeatButton#PART_PageUpButton,
                   ScrollBar.sideToolbarOverlay /template/ RepeatButton#PART_PageDownButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Opacity" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ Thumb">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="Template">
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="PART_Border"
                  Width="4"
                  MinWidth="4"
                  MaxWidth="4"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch"
                  Background="{DynamicResource ScrollBarThumbBrush}"
                  Opacity="0.4"
                  CornerRadius="2"
                  BorderThickness="0"
                  ClipToBounds="True"/>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ Thumb:pointerover /template/ Border#PART_Border">
      <Setter Property="Opacity" Value="0.5"/>
      <Setter Property="Background" Value="#C4C4C4"/>
    </Style>
    <Style Selector="ScrollBar.sideToolbarOverlay /template/ Thumb:pressed /template/ Border#PART_Border">
      <Setter Property="Opacity" Value="0.5"/>
      <Setter Property="Background" Value="#D9D9D9"/>
    </Style>
  </UserControl.Styles>
  <Grid RowDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ClipToBounds="False">
    <Grid Grid.Row="0" ClipToBounds="False">
      <ScrollViewer x:Name="MainTogglesScroll"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Hidden"
                    AllowAutoHide="False"
                    ClipToBounds="True">
        <c:PianoRollMainViewToggles LayoutOrientation="Vertical"
                                    ShowDiffSingerToolbar="{Binding IsDiffSingerTrack}"/>
      </ScrollViewer>
      <ScrollBar x:Name="MainTogglesVScroll" Classes="sideToolbarOverlay"
                 HorizontalAlignment="Right" VerticalAlignment="Stretch"
                 Width="10" Margin="0,0,0,0" ZIndex="1000"
                 Orientation="Vertical" AllowAutoHide="False"
                 Padding="0" ClipToBounds="False"
                 IsVisible="False"/>
    </Grid>
    <Border Grid.Row="1" Height="1" Margin="2,6,2,4" Background="{DynamicResource TickLineBrushLow}"
            IsVisible="{Binding IsDiffSingerTrack}"/>
    <c:PianoRollDiffSingerQualityToggles Grid.Row="2" LayoutOrientation="Vertical"
                                         IsVisible="{Binding IsDiffSingerTrack}"/>
    <Border Grid.Row="3" Height="1" Margin="2,6,2,4" Background="{DynamicResource TickLineBrushLow}"
            IsVisible="{Binding IsDiffSingerTrack}"/>
    <ToggleButton Grid.Row="4" Classes="sideToolbarToggle expressionDefaultsPanelToggle" Margin="0" Padding="0"
                  IsVisible="{Binding IsDiffSingerTrack}"
                  IsChecked="{Binding ShowExpressionDefaultsPanel}">
      <ToolTip.Tip>
        <TextBlock Text="{DynamicResource pianoroll.toggle.projectexpressions}" Foreground="{DynamicResource ToolTipForegroundBrush}"/>
      </ToolTip.Tip>
      <Grid Classes="toolbarIconHostSide">
        <Grid Classes="toolbarIconHostSideLayout">
          <Path Classes="stroked"
                Data="M 3 3 H 15 V 15 H 3 Z M 5 7 H 6.5 M 9 7 H 13 M 5 11 H 9 M 11.5 11 H 13 M 6.5 7 A 1 1 0 1 1 9 7 A 1 1 0 1 1 6.5 7 M 9 11 A 1 1 0 1 1 11.5 11 A 1 1 0 1 1 9 11"/>
        </Grid>
      </Grid>
    </ToggleButton>
    <ToggleButton Grid.Row="5" Classes="sideToolbarToggle diffSingerPanelToggle" Margin="0" Padding="0"
                  IsVisible="{Binding IsDiffSingerTrack}"
                  IsChecked="{Binding ShowDiffSingerPanel}">
      <ToolTip.Tip>
        <TextBlock Text="{DynamicResource pianoroll.toggle.render}" Foreground="{DynamicResource ToolTipForegroundBrush}"/>
      </ToolTip.Tip>
      <Grid Classes="toolbarIconHostSide">
        <Grid Classes="toolbarIconHostSideLayout">
          <TextBlock Classes="sideToolbarGlyph sideToolbarGlyphCompact" Text="DS"/>
        </Grid>
      </Grid>
    </ToggleButton>
    <ToggleButton Grid.Row="6" Classes="sideToolbarToggle appearanceToggle" Margin="0" Padding="0"
                  IsChecked="{Binding ShowAppearancePanel}">
      <ToolTip.Tip>
        <TextBlock Text="{DynamicResource pianoroll.toggle.view}" Foreground="{DynamicResource ToolTipForegroundBrush}"/>
      </ToolTip.Tip>
      <Grid Classes="toolbarIconHostSide">
        <Grid Classes="toolbarIconHostSideLayout">
          <Path Classes="filled" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z">
            <Path.RenderTransform>
              <TransformGroup>
                <ScaleTransform ScaleX=".575" ScaleY=".575"/>
                <TranslateTransform X="-1.5" Y="-1.5"/>
              </TransformGroup>
            </Path.RenderTransform>
          </Path>
        </Grid>
      </Grid>
    </ToggleButton>
  </Grid>
</UserControl>
