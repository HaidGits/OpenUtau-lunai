<UserControl xmlns="https://github.com/avaloniaui"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             xmlns:vm="using:OpenUtau.App.ViewModels"

             xmlns:c="using:OpenUtau.App.Controls"

             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="600"

             x:Class="OpenUtau.App.Controls.NotePropertiesControl"

             x:Name="NotePropsRoot"

             KeyDown="OnKeyDown" Focusable="True">

  <UserControl.Styles>

    <Style Selector="Button,CheckBox">

      <Setter Property="Focusable" Value="False"/>

    </Style>

    <Style Selector="TextBlock,TextBox,Slider,ComboBox,CheckBox">

      <Setter Property="VerticalAlignment" Value="Center"/>

    </Style>

    <Style Selector="TextBlock.notePropLabel">

      <Setter Property="TextWrapping" Value="Wrap"/>

      <Setter Property="VerticalAlignment" Value="Center"/>

      <Setter Property="Margin" Value="0,0,8,0"/>

    </Style>

    <Style Selector="Slider.fader">

      <Setter Property="Focusable" Value="True"/>

    </Style>

  </UserControl.Styles>



  <Grid>

    <TextBlock Text="{Binding Title}" Classes="notePropsPanelTitle"

               Height="32" Margin="16,16,40,0"

               HorizontalAlignment="Left" VerticalAlignment="Top"/>

    <Button x:Name="ClosePanelButton" Classes="workspacePanelClose"

            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"

            IsVisible="False" Click="OnCloseDockedPanel"

            ToolTip.Tip="{DynamicResource workspace.panel.close}">

      <Path/>

    </Button>

    <ScrollViewer Name="ContentScroll" Classes="workspaceScroll workspaceDockPanelScroll" Margin="10,48,10,10" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" AllowAutoHide="False">

      <StackPanel Classes="workspacePanelSections" Margin="0" HorizontalAlignment="Stretch">

        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"

                  Header="{DynamicResource noteproperty.basic}">

          <StackPanel Classes="workspacePanelSection" IsEnabled="{Binding IsNoteSelected}" Spacing="4">

          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.lyric}" Grid.Column="0"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Text="{Binding Lyric, Mode=OneWay}" Grid.Column="1" Grid.ColumnSpan="2" Tag="Lyric"/>

          </Grid>



          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource noteproperty.phonemizer}" Grid.Column="0"/>

            <Button Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"

                    Content="{Binding PhonemizerOverrideText}"

                    Click="OnPhonemizerButtonClicked">

              <Button.ContextMenu>

                <ContextMenu Name="PhonemizerMenu" ItemsSource="{Binding PhonemizerMenuItems}" Placement="Left">

                  <ContextMenu.Styles>

                    <Style Selector="MenuItem">

                      <Setter Property="Header" Value="{Binding Header}"/>

                      <Setter Property="Command" Value="{Binding Command, FallbackValue={x:Null}}"/>

                      <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>

                      <Setter Property="ItemsSource" Value="{Binding Items}"/>

                    </Style>

                  </ContextMenu.Styles>

                </ContextMenu>

              </Button.ContextMenu>

            </Button>

          </Grid>



          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource noteproperty.tone}" Grid.Column="0"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Text="{Binding Tone, Mode=OneWay}" Grid.Column="1" Grid.ColumnSpan="2" Tag="Tone" Margin="0"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource noteproperty.tuning}" FontWeight="{Binding TuningFontWeight}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding Tuning, Mode=OneWay}" Tag="Tuning" Margin="0"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding Tuning}" Minimum="-100" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="true"

                    Tag="Tuning"/>

          </Grid>

          </StackPanel>

        </Expander>

        <Separator Classes="workspacePanelSectionDivider"/>



        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"

                  Header="{DynamicResource notedefaults.portamento}">

          <StackPanel Classes="workspacePanelSection" IsEnabled="{Binding IsNoteSelected}" Spacing="4">

          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.preset}"/>

            <c:WorkspacePanelComboBox Grid.Column="1" Grid.ColumnSpan="2" Classes="workspacePanelCombo" ItemsSource="{Binding PortamentoPresets}" Margin="0"

              IsEnabled="{Binding IsNoteSelected}"

              SelectedItem="{Binding ApplyPortamentoPreset}" HorizontalAlignment="Stretch"/>

          </Grid>

          <Grid ColumnDefinitions="132,*,20,*">

            <Button Grid.Column="1" Classes="workspacePanelButton" Content="{DynamicResource notedefaults.preset.save}"

                    HorizontalAlignment="Stretch" Click="OnSavePortamentoPreset"

                    ToolTip.Tip="{DynamicResource notedefaults.preset.save.tooltip}"/>

            <Button Grid.Column="3" Classes="workspacePanelButton" Content="{DynamicResource notedefaults.preset.remove}"

                    HorizontalAlignment="Stretch" Command="{Binding RemoveAppliedPortamentoPreset}"

                    ToolTip.Tip="{DynamicResource notedefaults.preset.remove.tooltip}"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.portamento.length}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding PortamentoLength, Mode=OneWay}" Tag="PortamentoLength_TextBox"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding PortamentoLength}" Minimum="2" Maximum="320"

                    TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="true"

                    Tag="PortamentoLength"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.portamento.start}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding PortamentoStart, Mode=OneWay}" Tag="PortamentoStart_TextBox" Margin="0"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding PortamentoStart}" Minimum="-200" Maximum="200"

                    TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="true"

                    Tag="PortamentoStart"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource context.pitch.shape}"/>

            <c:WorkspacePanelComboBox Grid.Column="1" Grid.ColumnSpan="2" Classes="workspacePanelCombo" Margin="0"

              IsEnabled="{Binding IsNoteSelected}"

              SelectedIndex="{Binding PitchCurveShape}" HorizontalAlignment="Stretch">

              <ComboBoxItem Content="{DynamicResource context.pitch.easeinout}"/>

              <ComboBoxItem Content="{DynamicResource context.pitch.linear}"/>

              <ComboBoxItem Content="{DynamicResource context.pitch.easein}"/>

              <ComboBoxItem Content="{DynamicResource context.pitch.easeout}"/>

              <ComboBoxItem Content="{DynamicResource context.pitch.smooth}"/>

            </c:WorkspacePanelComboBox>

          </Grid>

          </StackPanel>

        </Expander>

        <Separator Classes="workspacePanelSectionDivider"/>



        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"

                  Header="{DynamicResource notedefaults.vibrato}">

          <StackPanel Classes="workspacePanelSection" IsEnabled="{Binding IsNoteSelected}" Spacing="4">

          <ToggleSwitch IsChecked="{Binding VibratoEnable, Mode=OneWay}" OnContent="{DynamicResource prefs.on}" OffContent="{DynamicResource prefs.off}"
                        Click="VibratoEnableClicked"/>

          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.preset}"/>

            <c:WorkspacePanelComboBox Grid.Column="1" Grid.ColumnSpan="2" Classes="workspacePanelCombo" ItemsSource="{Binding VibratoPresets}" Margin="0"

              IsEnabled="{Binding IsNoteSelected}"

              SelectedItem="{Binding ApplyVibratoPreset}" HorizontalAlignment="Stretch" />

          </Grid>

          <Grid ColumnDefinitions="132,*,20,*">

            <Button Grid.Column="1" Classes="workspacePanelButton" Content="{DynamicResource notedefaults.preset.save}"

                    HorizontalAlignment="Stretch" Click="OnSaveVibratoPreset"

                    ToolTip.Tip="{DynamicResource notedefaults.preset.save.tooltip}"/>

            <Button Grid.Column="3" Classes="workspacePanelButton" Content="{DynamicResource notedefaults.preset.remove}"

              HorizontalAlignment="Stretch" Command="{Binding RemoveAppliedVibratoPreset}"

              ToolTip.Tip="{DynamicResource notedefaults.preset.remove.tooltip}"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*" >

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.length}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoLength, Mode=OneWay}" Tag="VibratoLength"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoLength}" Minimum="0" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoLength" IsDirectionReversed="True" />

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.period}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoPeriod, Mode=OneWay}" Tag="VibratoPeriod"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoPeriod}" Minimum="5" Maximum="500"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoPeriod"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.depth}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoDepth, Mode=OneWay}" Tag="VibratoDepth"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoDepth}" Minimum="5" Maximum="200"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoDepth"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.in}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoIn, Mode=OneWay}" Tag="VibratoIn"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoIn}" Minimum="0" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoIn"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.out}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoOut, Mode=OneWay}" Tag="VibratoOut"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoOut}" Minimum="0" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoOut"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.shift}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoShift, Mode=OneWay}" Tag="VibratoShift"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoShift}" Minimum="0" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoShift"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.drift}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoDrift, Mode=OneWay}" Tag="VibratoDrift"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoDrift}" Minimum="-100" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoDrift"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.vollink}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" Text="{Binding VibratoVolLink, Mode=OneWay}" Tag="VibratoVolLink"/>

            <Slider Grid.Column="4" Classes="fader" Value="{Binding VibratoVolLink}" Minimum="-100" Maximum="100"

                    TickPlacement="BottomRight" TickFrequency="0.1" IsSnapToTickEnabled="true"

                    Tag="VibratoVolLink"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource noteproperty.setlongnote}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" IsChecked="{Binding AutoVibratoToggle}"/>

          </Grid>

          <Grid ColumnDefinitions="132,7,50,20,*">

            <TextBlock Classes="notePropLabel" Text="{DynamicResource notedefaults.vibrato.autominlength}"/>

            <c:WorkspacePanelTextBox Classes="workspacePanelTextBox" Grid.Column="2" IsEnabled="{Binding AutoVibratoToggle}" Text="{Binding AutoVibratoNoteLength}" Margin="0" />

            <Slider Grid.Column="4" Classes="fader" IsEnabled="{Binding AutoVibratoToggle}" Value="{Binding AutoVibratoNoteLength}" Minimum="10" Maximum="1920"

                    TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="true" />

          </Grid>

          </StackPanel>

        </Expander>

        <Separator Classes="workspacePanelSectionDivider"/>



        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"

                  Header="{DynamicResource exps.caption}">

          <StackPanel Classes="workspacePanelSection" Spacing="4">

            <StackPanel Name="ExpressionsPanel" Spacing="4" />

          </StackPanel>

        </Expander>

      </StackPanel>

    </ScrollViewer>

  </Grid>

</UserControl>

