<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenUtau.App.ViewModels"
             x:Class="OpenUtau.App.Controls.ThemePickerPreview"
             x:DataType="vm:ThemePickerItemViewModel">
  <Border Margin="1" ClipToBounds="True" CornerRadius="2">
    <Grid ColumnDefinitions="*,*,*,*,*,*">
      <Border Grid.Column="0" Background="{Binding CanvasBrush}"/>
      <Border Grid.Column="1" Background="{Binding BackgroundBrush}"/>
      <Border Grid.Column="2" Background="{Binding CardBrush}"/>
      <Border Grid.Column="3" Background="{Binding TrackAltBrush}"/>
      <Border Grid.Column="4" Background="{Binding NoteBrush}"/>
      <Border Grid.Column="5" Background="{Binding AccentBrush}"/>
    </Grid>
  </Border>
</UserControl>
