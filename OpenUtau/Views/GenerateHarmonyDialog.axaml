<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenUtau.App.ViewModels"
        x:Class="OpenUtau.App.Views.GenerateHarmonyDialog"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource dialogs.harmony.caption}">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock TextWrapping="Wrap"
               Text="{DynamicResource dialogs.harmony.description}"/>
    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
      <TextBlock Grid.Column="0" VerticalAlignment="Center" Classes="lbl" Margin="0,0,12,0"
                 Text="{DynamicResource dialogs.harmony.key}"/>
      <ComboBox x:Name="KeyComboBox" Grid.Column="1"
                SelectedItem="{Binding SelectedKeyOption}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:KeyOptionViewModel">
            <TextBlock Text="{Binding DisplayName}"/>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </Grid>
    <StackPanel Spacing="6">
      <TextBlock Classes="lbl" Text="{DynamicResource dialogs.harmony.intervals}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox VerticalAlignment="Center" IsChecked="{Binding ThirdAbove}"/>
        <TextBlock VerticalAlignment="Center" Text="{DynamicResource harmony.interval.thirdabove}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox VerticalAlignment="Center" IsChecked="{Binding ThirdBelow}"/>
        <TextBlock VerticalAlignment="Center" Text="{DynamicResource harmony.interval.thirdbelow}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox VerticalAlignment="Center" IsChecked="{Binding FifthAbove}"/>
        <TextBlock VerticalAlignment="Center" Text="{DynamicResource harmony.interval.fifthabove}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <CheckBox VerticalAlignment="Center" IsChecked="{Binding FifthBelow}"/>
        <TextBlock VerticalAlignment="Center" Text="{DynamicResource harmony.interval.fifthbelow}"/>
      </StackPanel>
    </StackPanel>
    <TextBlock Opacity="0.75" TextWrapping="Wrap"
               Text="{DynamicResource dialogs.harmony.hint}"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
      <Button MinWidth="80" Content="{DynamicResource button.cancel}" Click="OnCancel"/>
      <Button MinWidth="80" Content="{DynamicResource button.ok}" Classes="accent" Click="OnOk"/>
    </StackPanel>
  </StackPanel>
</Window>
