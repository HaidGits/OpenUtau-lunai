<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OpenUtau.App.ViewModels"
             xmlns:c="using:OpenUtau.App.Controls"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="OpenUtau.App.Views.ExpressionDefaultsPane"
             x:Name="ExpressionDefaultsRoot">
  <UserControl.Styles>
    <Style Selector="TextBlock.expDefaultLabel">
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.expDefaultLabelHit">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Margin" Value="0,0,4,0"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.expDefaultLabelHit:pointerover">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
    </Style>
    <Style Selector="TextBlock.expDefaultValue">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Right"/>
      <Setter Property="FontFamily" Value="monospace"/>
      <Setter Property="MinWidth" Value="36"/>
      <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>
    <Style Selector="Slider.fader">
      <Setter Property="Focusable" Value="True"/>
    </Style>
    <Style Selector="Grid.expDefaultRow">
      <Setter Property="Margin" Value="0,4,0,4"/>
    </Style>
    <Style Selector="StackPanel.expDefaultSectionContent">
      <Setter Property="Spacing" Value="2"/>
    </Style>
    <Style Selector="Border.expStyleChip">
      <Setter Property="Padding" Value="7,3"/>
      <Setter Property="Margin" Value="0,0,4,4"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
      <Setter Property="Background" Value="{DynamicResource WorkspaceCardBrush}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="MinHeight" Value="24"/>
    </Style>
    <Style Selector="Border.expStyleChip:pointerover">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1Brush}"/>
    </Style>
    <Style Selector="Border.expStyleChip TextBlock.expStyleChipName">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="MaxWidth" Value="120"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.expStyleChipDelete">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinWidth" Value="16"/>
      <Setter Property="MinHeight" Value="16"/>
      <Setter Property="Margin" Value="4,0,0,0"/>
      <Setter Property="Opacity" Value="0"/>
    </Style>
    <Style Selector="Border.expStyleChip:pointerover Button.expStyleChipDelete">
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
  </UserControl.Styles>
  <Design.DataContext>
    <vm:ExpressionDefaultsViewModel/>
  </Design.DataContext>
  <Grid>
    <TextBlock Text="{DynamicResource workspace.panel.expressions}" Classes="notePropsPanelTitle"
               Height="32" Margin="16,16,40,0"
               HorizontalAlignment="Left" VerticalAlignment="Top"/>
    <Button x:Name="ClosePanelButton" Classes="workspacePanelClose"
            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
            IsVisible="False" Click="OnCloseDockedPanel"
            ToolTip.Tip="{DynamicResource workspace.panel.close}">
      <Path Classes="stroked"/>
    </Button>
    <ScrollViewer x:Name="ContentScroll" Classes="workspaceScroll workspaceDockPanelScroll"
                  Margin="10,48,10,16"
                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                  AllowAutoHide="False">
      <StackPanel Classes="workspacePanelSections" Margin="0" HorizontalAlignment="Stretch">
        <Separator Classes="workspacePanelSectionDivider"/>
        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"
                  IsVisible="{Binding HasParameters}"
                  Header="{DynamicResource workspace.panel.expressions.parameters}">
          <StackPanel Classes="expDefaultSectionContent">
            <ItemsControl ItemsSource="{Binding ParameterItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExpressionDefaultItem">
                  <Grid Classes="expDefaultRow" ColumnDefinitions="110,*,Auto">
                    <Border Classes="expDefaultLabelHit" Grid.Column="0"
                            ToolTip.Tip="{DynamicResource workspace.panel.expressions.openinexppanel}"
                            PointerPressed="OnParameterNamePressed">
                      <TextBlock Classes="expDefaultLabel" Text="{Binding Name}"/>
                    </Border>
                    <c:ExpressionDefaultSlider Grid.Column="1" Item="{Binding}"/>
                    <TextBlock Classes="expDefaultValue" Grid.Column="2"
                               Text="{Binding DefaultValue, StringFormat={}{0:0}}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Expander>
        <Separator Classes="workspacePanelSectionDivider" IsVisible="{Binding HasVoiceColors}"/>
        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"
                  IsVisible="{Binding HasVoiceColors}"
                  Header="{DynamicResource workspace.panel.expressions.voicecolors}">
          <StackPanel Classes="expDefaultSectionContent">
            <Grid Classes="expDefaultRow" ColumnDefinitions="110,*"
                  IsVisible="{Binding ShowDefaultVoiceColorPicker}">
              <TextBlock Classes="expDefaultLabel" Margin="4,0,8,0"
                         Text="{DynamicResource workspace.panel.expressions.defaultcolor}"
                         Grid.Column="0"/>
              <c:WorkspacePanelComboBox Grid.Column="1" Classes="workspacePanelCombo"
                                        ItemsSource="{Binding VoiceColorOptions}"
                                        SelectedIndex="{Binding SelectedVoiceColorIndex}"/>
            </Grid>
            <ItemsControl ItemsSource="{Binding VoiceColorItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExpressionDefaultItem">
                  <Grid Classes="expDefaultRow" ColumnDefinitions="110,*,Auto">
                    <Border Classes="expDefaultLabelHit" Grid.Column="0"
                            ToolTip.Tip="{DynamicResource workspace.panel.expressions.openinexppanel}"
                            PointerPressed="OnParameterNamePressed">
                      <TextBlock Classes="expDefaultLabel" Text="{Binding Name}"/>
                    </Border>
                    <c:ExpressionDefaultSlider Grid.Column="1" Item="{Binding}"/>
                    <TextBlock Classes="expDefaultValue" Grid.Column="2"
                               Text="{Binding DefaultValue, StringFormat={}{0:0}}"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Expander>

        <Separator Classes="workspacePanelSectionDivider"/>
        <Expander Classes="workspacePanelSectionExpander" IsExpanded="True"
                  Header="{DynamicResource workspace.panel.expressions.styles}">
          <StackPanel Classes="expDefaultSectionContent" Spacing="6">
            <Button HorizontalAlignment="Stretch"
                    IsEnabled="{Binding CanSaveStyle}"
                    Click="OnSaveStyleClick"
                    Content="{DynamicResource workspace.panel.expressions.styles.save}"
                    ToolTip.Tip="{DynamicResource workspace.panel.expressions.styles.save.tip}"/>
            <TextBlock Opacity="0.55" FontSize="11" TextWrapping="Wrap"
                       IsVisible="{Binding !HasStyles}"
                       Text="{DynamicResource workspace.panel.expressions.styles.empty.list}"/>
            <ItemsControl ItemsSource="{Binding StyleItems}" IsVisible="{Binding HasStyles}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ExpressionStyleItemViewModel">
                  <Border Classes="expStyleChip"
                          ToolTip.Tip="{Binding ToolTipText}"
                          PointerPressed="OnStyleChipPointerPressed">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                      <TextBlock Classes="expStyleChipName" Text="{Binding Name}"/>
                      <Button Classes="iconButton expStyleChipDelete"
                              Click="OnStyleDeleteClick"
                              ToolTip.Tip="{DynamicResource workspace.panel.expressions.styles.delete}">
                        <Viewbox Width="10" Height="10">
                          <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"/>
                        </Viewbox>
                      </Button>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Expander>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
