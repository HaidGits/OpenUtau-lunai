<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OpenUtau.App.ViewModels"
             xmlns:c="using:OpenUtau.App.Controls"
             xmlns:views="clr-namespace:OpenUtau.App.Views"
             mc:Ignorable="d" d:DesignWidth="500"
             x:Class="OpenUtau.App.Views.PreferencesAppearancePane">
  <Design.DataContext>
    <vm:PreferencesViewModel/>
  </Design.DataContext>
  <StackPanel>
    <TextBlock Text="{DynamicResource prefs.appearance.section.theme}" Margin="0,10,0,0" FontWeight="Bold"/>
    <views:ThemePickerControl DataContext="{Binding}"/>

    <TextBlock Text="{DynamicResource prefs.appearance.section.pianoroll}" Margin="0,16,0,0" FontWeight="Bold"/>
    <TextBlock Text="{DynamicResource prefs.appearance.degree}" Margin="0,10,0,0" FontWeight="Bold"/>
    <c:WorkspacePanelComboBox Classes="workspacePanelCombo" HorizontalAlignment="Stretch"
                              SelectedIndex="{Binding DegreeStyle}">
      <ComboBoxItem Content="{DynamicResource prefs.appearance.degree.off}"/>
      <ComboBoxItem Content="{DynamicResource prefs.appearance.degree.solfege}"/>
      <ComboBoxItem Content="{DynamicResource prefs.appearance.degree.numbered}"/>
    </c:WorkspacePanelComboBox>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.trackcolor}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding UseTrackColor}"/>
    </Grid>
    <Grid IsEnabled="{Binding UseTrackColor}">
      <TextBlock Text="{DynamicResource prefs.appearance.tintpianorollbackgroundwithtrackcolor}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding TintPianoRollBackgroundWithTrackColor}"/>
    </Grid>
    <TextBlock Text="{DynamicResource prefs.appearance.defaulttrackcolor}" Margin="0,10,0,0" FontWeight="Bold"/>
    <ListBox ItemsSource="{Binding TrackColors}" SelectedItem="{Binding DefaultTrackColor}"
             Classes="defaultTrackColorPicker" Background="Transparent" HorizontalAlignment="Stretch">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse Width="16" Height="16" Fill="{Binding AccentColor}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Ellipse Width="20" Height="20" Fill="Transparent" Stroke="White" StrokeThickness="2"
                     IsVisible="{Binding $parent[ListBoxItem].IsSelected}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
      <ListBox.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ListBox.ItemsPanel>
      <ListBox.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="ToolTip.Tip" Value="{Binding Name}"/>
          <Setter Property="Padding" Value="1"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
          <Setter Property="Background" Value="Transparent"/>
        </Style>
      </ListBox.Styles>
    </ListBox>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.showportrait}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding ShowPortrait}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.showicon}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding ShowIcon}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.showghostnotes}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding ShowGhostNotes}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.shownoteborder}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding ShowNoteBorder}"/>
    </Grid>
    <Grid ColumnDefinitions="Auto,8,20,8,*" Margin="0,10,0,0">
      <TextBlock Grid.Column="0" Text="{DynamicResource prefs.appearance.notecornerradius}"/>
      <TextBlock Grid.Column="2">
        <TextBlock.Text>
          <Binding Path="NoteCornerRadius" StringFormat="{}{0:0.#} px"/>
        </TextBlock.Text>
      </TextBlock>
      <Slider Grid.Column="4" Classes="fader" Minimum="0" Maximum="12" TickFrequency="1"
              IsSnapToTickEnabled="true" Value="{Binding NoteCornerRadius}"/>
    </Grid>

    <TextBlock Text="{DynamicResource prefs.appearance.section.grid}" Margin="0,16,0,0" FontWeight="Bold"/>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.solidtickgridlines}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding SolidTickGridLines}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.overlayscrollbars}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding UseOverlayScrollbars}"/>
    </Grid>
    <TextBlock Classes="restart"/>

    <TextBlock Text="{DynamicResource prefs.appearance.section.expressions}" Margin="0,16,0,0" FontWeight="Bold"/>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.solidexppanelgridlines}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding SolidExpPanelGridLines}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.appearance.diffsingerlangcodehide}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding DiffSingerLangCodeHide}"/>
    </Grid>
    <Grid>
      <TextBlock Text="{DynamicResource prefs.diffsinger.phonemepanel}" HorizontalAlignment="Left"/>
      <ToggleSwitch IsChecked="{Binding DiffSingerPhonemePanelMode}"/>
    </Grid>
  </StackPanel>
</UserControl>
