<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="OpenUtau.App.Views.UpdaterDialog"
        Width="460" MinHeight="360" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/open-utau.ico"
        Title="{DynamicResource updater.caption}" Closing="OnClosing">
  <Grid Margin="24,20,24,24" RowDefinitions="Auto,*,Auto">
    <StackPanel Grid.Row="0" Spacing="8" HorizontalAlignment="Center">
      <Image Width="110" Height="110" HorizontalAlignment="Center"
             Source="/Assets/open-utau.ico"/>
      <Image Height="60" HorizontalAlignment="Center" Margin="0,8,0,0"
             Source="/Assets/logotype.png" IsVisible="{Binding !IsDarkMode}"/>
      <Image Height="60" HorizontalAlignment="Center" Margin="0,8,0,0"
             Source="/Assets/logotype-w.png" IsVisible="{Binding IsDarkMode}"/>
      <TextBlock Margin="0,8,0,0" TextAlignment="Center"
                 Text="{Binding AppVersion}"/>
      <TextBlock TextAlignment="Center" TextWrapping="Wrap"
                 Text="{DynamicResource updater.description}"/>
    </StackPanel>

    <TextBlock Grid.Row="1" Margin="0,16" TextAlignment="Center" VerticalAlignment="Center"
               TextWrapping="Wrap" Text="{Binding UpdaterStatus}" FontWeight="Bold"/>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
      <Button Width="120" Content="{DynamicResource updater.github}" Command="{Binding OnGithub}"/>
      <Button Width="120" Content="{DynamicResource updater.update}" Command="{Binding OnUpdate}"
              IsEnabled="{Binding UpdateAvailable}"
              FontWeight="{Binding UpdateButtonFontWeight}"/>
    </StackPanel>
  </Grid>
</Window>
