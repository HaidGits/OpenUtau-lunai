<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OpenUtau.App.ViewModels"
             xmlns:c="using:OpenUtau.App.Controls"
             mc:Ignorable="d" d:DesignWidth="300"
             x:Class="OpenUtau.App.Views.ThemePickerControl">
  <UserControl.Styles>
    <Style Selector="Border.themePickerTile">
      <Setter Property="Width" Value="60"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="Margin" Value="0,0,4,4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Border.themePickerTile:pointerover:not(:pressed)">
      <Setter Property="Background" Value="{DynamicResource TransportToolbarOffHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1Brush}"/>
    </Style>
    <Style Selector="Border.themePickerTile:pressed">
      <Setter Property="Background" Value="{DynamicResource AppTopBarTransportHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorLight1Brush}"/>
    </Style>
    <Style Selector="Border.themePickerTile.selected:not(:pointerover):not(:pressed)">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark1Brush}"/>
    </Style>
    <Style Selector="Border.themePickerTile:disabled">
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style Selector="Border.themePickerTile Panel.themePickerActions">
      <Setter Property="IsVisible" Value="False"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
      <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="Border.themePickerTile Panel.themePickerActions > StackPanel">
      <Setter Property="HorizontalAlignment" Value="Center"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Border.themePickerTile.themePickerEditable:pointerover Panel.themePickerActions">
      <Setter Property="IsVisible" Value="True"/>
    </Style>
    <Style Selector="TextBlock.themePickerSectionLabel">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,2,0,3"/>
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
    </Style>
    <Style Selector="Border.themePreviewStrip">
      <Setter Property="Height" Value="34"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="ClipToBounds" Value="True"/>
    </Style>
    <Style Selector="TextBlock.themePickerTileLabel">
      <Setter Property="Margin" Value="0,4,0,0"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
      <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
    </Style>
    <Style Selector="Button.themePickerActionButton">
      <Setter Property="Width" Value="22"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinWidth" Value="22"/>
      <Setter Property="MinHeight" Value="22"/>
    </Style>
  </UserControl.Styles>
  <StackPanel Spacing="4">
    <TextBlock Classes="themePickerSectionLabel"
               Text="{DynamicResource prefs.appearance.theme.builtin}"/>
    <ItemsControl ItemsSource="{Binding BuiltInThemePickerItems}"
                  IsEnabled="{Binding !IsThemeEditorOpen}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ThemePickerItemViewModel">
          <Border Classes="themePickerTile"
                  Classes.selected="{Binding IsSelected}"
                  Classes.themePickerEditable="{Binding IsEditable}"
                  PointerPressed="OnThemeTilePointerPressed"
                  ToolTip.Tip="{Binding DisplayName}">
            <Grid RowDefinitions="Auto,Auto">
              <Border Grid.Row="0" Classes="themePreviewStrip">
                <c:ThemePickerPreview/>
              </Border>
              <TextBlock Grid.Row="1" Classes="themePickerTileLabel"
                         Text="{Binding DisplayName}"/>
              <Panel Grid.Row="0" Classes="themePickerActions">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Classes="iconButton themePickerActionButton"
                          IsVisible="{Binding IsEditable}"
                          Click="OnThemeEditClick"
                          ToolTip.Tip="{DynamicResource prefs.appearance.customtheme.edit.title}">
                    <Viewbox Width="14" Height="14">
                      <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Classes="filled"
                            Data="M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z"/>
                    </Viewbox>
                  </Button>
                  <Button Classes="iconButton themePickerActionButton"
                          IsVisible="{Binding IsEditable}"
                          Click="OnThemeDeleteClick"
                          ToolTip.Tip="{DynamicResource prefs.appearance.customtheme.delete.title}">
                    <Viewbox Width="14" Height="14" Margin="-2,-1,0,0">
                      <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M7.03 2.81c-.23 0-.38.17-.38.37v1.27h-2.65c-.19 0-.38.17-.38.37v.29c0 .21.19.37.38.37h.26v8.9c0 .21.19.37.38.37h8.7c.23 0 .38-.17.38-.42V5.68h.26c.23 0 .38-.17.38-.37v-.29c0-.21-.15-.42-.38-.42h-2.65V3.22c0-.21-.15-.42-.38-.42H7.05zm.76 1.04h2.42v.75h-2.38v-.75zm-2.49 1.79h7.4v8.23H5.29V6.28zm1.82 1.49a.38.38 0 0 0-.38.42v4.32c0 .21.19.42.38.42h.42a.38.38 0 0 0 .38-.42V7.77a.38.38 0 0 0-.38-.42h-.42zm3.37 0a.38.38 0 0 0-.38.42v4.32c0 .21.15.42.38.42h.38a.38.38 0 0 0 .38-.42V7.77a.38.38 0 0 0-.38-.42h-.38z"/>
                    </Viewbox>
                  </Button>
                </StackPanel>
              </Panel>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <TextBlock Classes="themePickerSectionLabel"
               Text="{DynamicResource prefs.appearance.theme.builtin.custom}"/>
    <ItemsControl ItemsSource="{Binding BuiltInCustomThemePickerItems}"
                  IsEnabled="{Binding !IsThemeEditorOpen}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ThemePickerItemViewModel">
          <Border Classes="themePickerTile"
                  Classes.selected="{Binding IsSelected}"
                  PointerPressed="OnThemeTilePointerPressed"
                  ToolTip.Tip="{Binding DisplayName}">
            <Grid RowDefinitions="Auto,Auto">
              <Border Grid.Row="0" Classes="themePreviewStrip">
                <c:ThemePickerPreview/>
              </Border>
              <TextBlock Grid.Row="1" Classes="themePickerTileLabel"
                         Text="{Binding DisplayName}"/>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <TextBlock Classes="themePickerSectionLabel"
               Text="{DynamicResource prefs.appearance.theme.custom}"/>
    <ItemsControl ItemsSource="{Binding CustomThemePickerItems}"
                  IsEnabled="{Binding !IsThemeEditorOpen}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:ThemePickerItemViewModel">
          <Border Classes="themePickerTile"
                  Classes.selected="{Binding IsSelected}"
                  Classes.themePickerEditable="{Binding IsEditable}"
                  Classes.themePickerCreate="{Binding IsCreateTile}"
                  PointerPressed="OnThemeTilePointerPressed"
                  ToolTip.Tip="{Binding DisplayName, TargetNullValue={x:Null}}">
            <Grid RowDefinitions="Auto,Auto">
              <Border Grid.Row="0" Classes="themePreviewStrip"
                      IsVisible="{Binding !IsCreateTile}">
                <c:ThemePickerPreview/>
              </Border>
              <Border Grid.Row="0" Classes="themePreviewStrip"
                      IsVisible="{Binding IsCreateTile}"
                      Background="Transparent"
                      ToolTip.Tip="{DynamicResource prefs.appearance.customtheme.create.title}">
                <Path Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Fill="{DynamicResource MutedIconBrush}"
                      Data="M8.43 3.33 a0.38 0.38 0 0 0 -0.38 0.38 v4.35 H3.7 a0.38 0.38 0 0 0 -0.38 0.38 v1.13 c0 0.23 0.19 0.38 0.38 0.38 h4.35 v4.35 c0 0.23 0.19 0.38 0.38 0.38 h1.13 a0.38 0.38 0 0 0 0.38 -0.38 V9.97 h4.35 a0.38 0.38 0 0 0 0.38 -0.38 v-1.13 a0.38 0.38 0 0 0 -0.38 -0.38 H9.97 V3.7 a0.38 0.38 0 0 0 -0.38 -0.38 h-1.13 z"/>
              </Border>
              <TextBlock Grid.Row="1" Classes="themePickerTileLabel"
                         Text="{Binding DisplayName}"
                         IsVisible="{Binding !IsCreateTile}"/>
              <TextBlock Grid.Row="1" Classes="themePickerTileLabel"
                         Text="{DynamicResource prefs.appearance.customtheme.create.short}"
                         IsVisible="{Binding IsCreateTile}"
                         Foreground="{DynamicResource MutedIconBrush}"/>
              <Panel Grid.Row="0" Classes="themePickerActions">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Button Classes="iconButton themePickerActionButton"
                          IsVisible="{Binding IsEditable}"
                          Click="OnThemeEditClick"
                          ToolTip.Tip="{DynamicResource prefs.appearance.customtheme.edit.title}">
                    <Viewbox Width="14" Height="14">
                      <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Classes="filled"
                            Data="M14.06,9L15,9.94L5.92,19H5V18.08L14.06,9M17.66,3C17.41,3 17.15,3.1 16.96,3.29L15.13,5.12L18.88,8.87L20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18.17,3.09 17.92,3 17.66,3M14.06,6.19L3,17.25V21H6.75L17.81,9.94L14.06,6.19Z"/>
                    </Viewbox>
                  </Button>
                  <Button Classes="iconButton themePickerActionButton"
                          IsVisible="{Binding IsEditable}"
                          Click="OnThemeDeleteClick"
                          ToolTip.Tip="{DynamicResource prefs.appearance.customtheme.delete.title}">
                    <Viewbox Width="14" Height="14" Margin="-2,-1,0,0">
                      <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            Data="M7.03 2.81c-.23 0-.38.17-.38.37v1.27h-2.65c-.19 0-.38.17-.38.37v.29c0 .21.19.37.38.37h.26v8.9c0 .21.19.37.38.37h8.7c.23 0 .38-.17.38-.42V5.68h.26c.23 0 .38-.17.38-.37v-.29c0-.21-.15-.42-.38-.42h-2.65V3.22c0-.21-.15-.42-.38-.42H7.05zm.76 1.04h2.42v.75h-2.38v-.75zm-2.49 1.79h7.4v8.23H5.29V6.28zm1.82 1.49a.38.38 0 0 0-.38.42v4.32c0 .21.19.42.38.42h.42a.38.38 0 0 0 .38-.42V7.77a.38.38 0 0 0-.38-.42h-.42zm3.37 0a.38.38 0 0 0-.38.42v4.32c0 .21.15.42.38.42h.38a.38.38 0 0 0 .38-.42V7.77a.38.38 0 0 0-.38-.42h-.38z"/>
                    </Viewbox>
                  </Button>
                </StackPanel>
              </Panel>
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
