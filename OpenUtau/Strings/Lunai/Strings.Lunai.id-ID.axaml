<!--Lunai overlay for id-ID. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Buat harmoni...</system:String>

  <system:String x:Key="dialogs.about.close">Tutup</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Menampilkan daftar kontributor bawaan.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Orang-orang ini berkontribusi pada repositori OpenUtau asli di GitHub. OpenUtau Lunai dibangun di atas karya mereka. Terima kasih kepada semua yang tercantum!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Memuat kontributor dari GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Kontributor</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Tidak dapat memuat kontributor. Periksa koneksi internet Anda dan coba lagi.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Daftar kontributor diperbarui dari GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai di GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau di GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau dan OpenUtau Lunai adalah perangkat lunak sumber terbuka gratis di bawah lisensi MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Anda menjalankan OpenUtau Lunai, fork yang bertujuan membuat DiffSinger lebih mudah dan lebih menyenangkan digunakan. Bank UTAU klasik dan semua jenis voicebank lain yang sudah didukung OpenUtau tetap berfungsi seperti biasa. Juga menyertakan banyak fitur dari pull request upstream yang belum dirilis atau digabungkan ke OpenUtau asli.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau bertujuan menjadi lingkungan penyuntingan sumber terbuka untuk komunitas UTAU, dengan pengalaman pengguna modern dan dukungan fonologi yang cerdas. Kunjungi kami di Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau bertujuan menjadi lingkungan penyuntingan sumber terbuka untuk komunitas UTAU, dengan pengalaman pengguna modern dan dukungan fonologi yang cerdas.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Buka atau impor proyek</system:String>
  <system:String x:Key="dialogs.dropproject.import">Impor trek</system:String>
  <system:String x:Key="dialogs.dropproject.message">Apakah Anda ingin membuka berkas proyek yang dijatuhkan, atau mengimpor treknya ke proyek saat ini?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Buka proyek</system:String>
  <system:String x:Key="dialogs.exportds.caption">Ekspor skrip DiffSinger</system:String>
