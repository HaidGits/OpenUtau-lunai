  <system:String x:Key="pianoroll.tool.drawpitch">Alat Gambar Nada (4)
    Klik kiri untuk menggambar
    Klik kanan untuk mengatur ulang
    Tahan Ctrl untuk memilih</system:String>
  <system:String x:Key="pianoroll.tool.knife">Alat Pisau (5)</system:String>
  <system:String x:Key="pianoroll.tool.pitchesinewave">Alat Gelombang Sinus Nada (Shift + 3)
    Seret untuk menggambar gelombang sinus, lepaskan untuk masuk mode penyesuaian
    Gerakkan mouse untuk menyesuaikan panjang gelombang dan amplitudo, klik untuk menerapkan
    Klik kanan untuk mengatur ulang
    Tahan Ctrl untuk memilih</system:String>
  <system:String x:Key="pianoroll.tool.pitchline">Alat Garis Nada (Shift + 1)
    Klik kiri untuk menggambar garis lurus
    Klik kanan untuk mengatur ulang
    Tahan Ctrl untuk memilih</system:String>
  <system:String x:Key="pianoroll.tool.pitchscurve">Alat Kurva-S Nada (Shift + 2)
    Seret untuk menggambar kurva-S, lepaskan untuk masuk mode penyesuaian
    Gerakkan mouse untuk menyesuaikan kekuatan kurva-S, klik untuk menerapkan
    Klik kanan untuk mengatur ulang
    Tahan Ctrl untuk memilih</system:String>
  <system:String x:Key="pianoroll.tool.pitchsmoothen">Alat Haluskan Nada (Shift + 4)
    Klik kiri untuk menghaluskan nada
    Klik kanan untuk mengatur ulang
    Tahan Ctrl untuk memilih</system:String>

