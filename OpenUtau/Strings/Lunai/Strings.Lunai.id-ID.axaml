  <system:String x:Key="dialogs.reportissue.email.copy">Salin alamat</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Tulis kepada kami dan lampirkan log jika masalahnya sulit direproduksi.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">Email</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Tulis email</system:String>
  <system:String x:Key="dialogs.reportissue.message">Beritahu kami apa yang salah. Lebih baik Discord #help agar kami bisa membalas cepat; sertakan berkas log jika membantu. Anda juga bisa mengirim email.</system:String>

