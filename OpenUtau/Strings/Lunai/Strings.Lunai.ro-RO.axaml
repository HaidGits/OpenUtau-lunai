  <system:String x:Key="dialogs.reportissue.email.description">Scrieți-ne și atașați un jurnal dacă problema este greu de reprodus.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Scrie e-mail</system:String>
  <system:String x:Key="dialogs.reportissue.message">Spuneți-ne ce nu a funcționat. Preferați Discord #help pentru a vă putea răspunde rapid; includeți un fișier jurnal când ajută. Ne puteți scrie și prin e-mail.</system:String>

