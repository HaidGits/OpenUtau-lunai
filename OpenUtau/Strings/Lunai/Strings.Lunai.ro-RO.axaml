<!--Lunai overlay for ro-RO. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Generează armonii...</system:String>

  <system:String x:Key="dialogs.about.close">Închide</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Se afișează lista încorporată a contribuitorilor.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Aceste persoane au contribuit la depozitul original OpenUtau de pe GitHub. OpenUtau Lunai se bazează pe munca lor. Mulțumim tuturor celor enumerați!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Se încarcă contribuitorii de pe GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Contribuitori</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Contribuitorii nu au putut fi încărcați. Verifică conexiunea la internet și încearcă din nou.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Lista contribuitorilor a fost actualizată de pe GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai pe GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau pe GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau și OpenUtau Lunai sunt programe gratuite cu sursă deschisă, sub licența MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Rulați OpenUtau Lunai, un fork creat pentru a face DiffSinger mai simplu și mai plăcut de utilizat. Băncile UTAU clasice și toate celelalte tipuri de bănci vocale deja acceptate de OpenUtau funcționează în continuare ca de obicei. Include și multe funcții din pull request-uri upstream care încă nu sunt lansate sau integrate în OpenUtau original.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau își propune să fie un mediu de editare cu sursă deschisă pentru comunitatea UTAU, cu o experiență modernă și suport fonologic inteligent. Vizitează-ne pe GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau își propune să fie un mediu de editare cu sursă deschisă pentru comunitatea UTAU, cu o experiență modernă și suport fonologic inteligent.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Deschide or import proiect</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importă piste</system:String>
  <system:String x:Key="dialogs.dropproject.message">Doriți să deschideți fișierul de proiect plasat sau să importați pistele sale în proiectul curent?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Deschide proiect</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exportă DiffSinger script</system:String>
  <system:String x:Key="dialogs.exportds.variance">Variație parametri</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Activați memoria cache de tensori DiffSinger în Preferințe pentru a exporta curbele parametrilor de variație.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Generate Armonii</system:String>
  <system:String x:Key="dialogs.harmony.description">Creați piste noi de armonie din partea selectată. Notele sunt transpuse diatonic în tonalitatea aleasă.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Fiecare voce selectată creează o pistă nouă sub cea sursă, cu note transpuse. Interpretul și setările sunt copiate de pe pista sursă.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Voci de armonie</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonalitate</system:String>
