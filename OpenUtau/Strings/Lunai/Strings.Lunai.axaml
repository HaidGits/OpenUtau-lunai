  <system:String x:Key="dialogs.about.close">Close</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Showing the embedded contributor list.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">These people contributed to the original OpenUtau repository on GitHub. OpenUtau Lunai builds on their work. Thank you to everyone listed!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Loading contributors from GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Contributors</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Could not load contributors. Check your internet connection and try again.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Contributor list updated from GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai on GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau on GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau and OpenUtau Lunai are free open-source software under the MIT license.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">You are running OpenUtau Lunai, a fork aimed at making DiffSinger easier and more enjoyable to use. Classic UTAU banks and all other voicebank types OpenUtau already supports still work as usual. It also includes many features from upstream pull requests that are not yet released or merged into the original OpenUtau.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau aims to be an open source editing environment for UTAU community, with a modern user experience and intelligent phonological support. Visit us on Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau aims to be an open source editing environment for the UTAU community, with a modern user experience and intelligent phonological support.</system:String>
