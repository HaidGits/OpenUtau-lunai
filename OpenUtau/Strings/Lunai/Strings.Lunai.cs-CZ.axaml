  <system:String x:Key="dialogs.messagebox.openpackages">Správce balíčků</system:String>
  <system:String x:Key="dialogs.reportissue.discord.description">Připojte se k našemu serveru a popište chybu v #help. V případě potřeby přiložte protokol přes Nápověda → Otevřít umístění protokolů.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Otevřít Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Kopírovat adresu</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Napište nám a přiložte protokol, pokud se problém obtížně reprodukuje.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Napsat e-mail</system:String>
  <system:String x:Key="dialogs.reportissue.message">Popište, co se pokazilo. Upřednostněte Discord #help, abychom mohli rychle odpovědět; pokud pomůže, přiložte soubor protokolu. Můžete nám také napsat e-mail.</system:String>

