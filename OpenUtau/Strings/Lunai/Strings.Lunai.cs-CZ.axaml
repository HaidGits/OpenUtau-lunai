<!--Lunai overlay for cs-CZ. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Generovat harmonie...</system:String>

  <system:String x:Key="dialogs.about.close">Zavřít</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Zobrazuje se vložený seznam přispěvatelů.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Tito lidé přispěli do původního repozitáře OpenUtau na GitHubu. OpenUtau Lunai staví na jejich práci. Děkujeme všem uvedeným!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Načítání přispěvatelů z GitHubu...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Přispěvatelé</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Přispěvatele se nepodařilo načíst. Zkontrolujte připojení k internetu a zkuste to znovu.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Seznam přispěvatelů byl aktualizován z GitHubu.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai na GitHubu</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau na GitHubu</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau a OpenUtau Lunai jsou svobodný software s otevřeným zdrojovým kódem pod licencí MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Používáte OpenUtau Lunai, fork zaměřený na jednodušší a příjemnější práci s DiffSinger. Klasické banky UTAU a všechny ostatní typy hlasových bank, které OpenUtau již podporuje, nadále fungují jako obvykle. Obsahuje také mnoho funkcí z upstream pull requestů, které zatím nebyly vydány ani sloučeny do původního OpenUtau.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau si klade za cíl být editačním prostředím s otevřeným zdrojovým kódem pro komunitu UTAU s moderním uživatelským prostředím a inteligentní fonologickou podporou. Navštivte nás na GitHubu.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau si klade za cíl být editačním prostředím s otevřeným zdrojovým kódem pro komunitu UTAU s moderním uživatelským prostředím a inteligentní fonologickou podporou.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Otevřít or import projekt</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importovat stopy</system:String>
  <system:String x:Key="dialogs.dropproject.message">Chcete otevřít přetažený soubor projektu, nebo importovat jeho stopy do aktuálního projektu?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Otevřít projekt</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exportovat DiffSinger skript</system:String>
  <system:String x:Key="dialogs.exportds.variance">Variabilita parametry</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Chcete-li exportovat křivky parametrů variability, povolte v Předvolbách tensorovou mezipaměť DiffSinger.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Generate Harmonie</system:String>
  <system:String x:Key="dialogs.harmony.description">Vytvořte nové harmonické stopy z vybrané části. Noty jsou diatonicky transponovány do zvolené tóniny.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Každý vybraný hlas vytvoří pod zdrojovou stopou novou stopu s transponovanými notami. Zpěvák a nastavení se zkopírují ze zdrojové stopy.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Hlasy harmonie</system:String>
  <system:String x:Key="dialogs.harmony.key">Tónina</system:String>
  <system:String x:Key="dialogs.importproject.caption">Importovat projekt options</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Čínské hanzi → Pinyin</system:String>
