  <system:String x:Key="dialogs.reportissue.discord.description">Rejoignez notre serveur et décrivez le bug dans #help. Joignez un journal via Aide → Ouvrir l’emplacement des journaux si besoin.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Ouvrir Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Copier l’adresse</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Écrivez-nous et joignez un journal si le problème est difficile à reproduire.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Écrire un e-mail</system:String>
  <system:String x:Key="dialogs.reportissue.message">Dites-nous ce qui s’est mal passé. Préférez Discord #help pour une réponse rapide ; joignez un fichier journal si cela aide. Vous pouvez aussi nous écrire par e-mail.</system:String>

