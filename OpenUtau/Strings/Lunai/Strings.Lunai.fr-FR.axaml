  <system:String x:Key="pianoroll.tool.drawpitch">Outil Dessiner le pitch (4)
    Clic gauche pour dessiner
    Clic droit pour réinitialiser
    Maintenir Ctrl pour sélectionner</system:String>
  <system:String x:Key="pianoroll.tool.knife">Outil Cutter (5)</system:String>
  <system:String x:Key="pianoroll.tool.pitchesinewave">Outil Sinusoïde de pitch (Shift + 3)
    Faire glisser pour dessiner une sinusoïde, relâcher pour le mode réglage
    Déplacer la souris pour ajuster longueur d’onde et amplitude, cliquer pour appliquer
    Clic droit pour réinitialiser
    Maintenir Ctrl pour sélectionner</system:String>
  <system:String x:Key="pianoroll.tool.pitchline">Outil Ligne de pitch (Shift + 1)
    Clic gauche pour tracer une ligne droite
    Clic droit pour réinitialiser
    Maintenir Ctrl pour sélectionner</system:String>
  <system:String x:Key="pianoroll.tool.pitchscurve">Outil Courbe en S du pitch (Shift + 2)
    Faire glisser pour dessiner une courbe en S, relâcher pour le mode réglage
    Déplacer la souris pour régler la force de la courbe, cliquer pour appliquer
    Clic droit pour réinitialiser
    Maintenir Ctrl pour sélectionner</system:String>
  <system:String x:Key="pianoroll.tool.pitchsmoothen">Outil Lissage du pitch (Shift + 4)
    Clic gauche pour lisser le pitch
    Clic droit pour réinitialiser
    Maintenir Ctrl pour sélectionner</system:String>

