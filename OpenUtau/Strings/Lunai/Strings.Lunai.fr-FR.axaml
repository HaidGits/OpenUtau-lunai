<!--Lunai overlay for fr-FR. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Générer des harmonies...</system:String>

  <system:String x:Key="dialogs.about.close">Fermer</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Affichage de la liste intégrée des contributeurs.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Ces personnes ont contribué au dépôt OpenUtau d’origine sur GitHub. OpenUtau Lunai s’appuie sur leur travail. Merci à toutes les personnes listées !</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Chargement des contributeurs depuis GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Contributeurs</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Impossible de charger les contributeurs. Vérifiez votre connexion Internet et réessayez.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Liste des contributeurs mise à jour depuis GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai sur GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau sur GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau et OpenUtau Lunai sont des logiciels libres open source sous licence MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Vous utilisez OpenUtau Lunai, un fork conçu pour rendre DiffSinger plus simple et plus agréable. Les banques UTAU classiques et tous les autres types de voicebanks déjà pris en charge par OpenUtau fonctionnent toujours normalement. Il inclut aussi de nombreuses fonctionnalités issues de pull requests amont pas encore publiées ni fusionnées dans OpenUtau d’origine.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau vise à être un environnement d’édition open source pour la communauté UTAU, avec une expérience moderne et un support phonologique intelligent. Rendez-nous visite sur Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau vise à être un environnement d’édition open source pour la communauté UTAU, avec une expérience moderne et un support phonologique intelligent.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Ouvrir ou importer un projet</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importer les pistes</system:String>
  <system:String x:Key="dialogs.dropproject.message">Voulez-vous ouvrir le fichier projet déposé, ou importer ses pistes dans le projet actuel ?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Ouvrir le projet</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exporter le script DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Paramètres de variance</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Activez le cache tensoriel DiffSinger dans les Préférences pour exporter les courbes de paramètres de variance.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Générer des harmonies</system:String>
  <system:String x:Key="dialogs.harmony.description">Crée de nouvelles pistes d’harmonie à partir de la partie sélectionnée. Les notes sont transposées diatoniquement dans la tonalité choisie.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Chaque voix sélectionnée crée une nouvelle piste sous la source avec des notes transposées. Le chanteur et les réglages sont copiés depuis la piste source.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Voix d’harmonie</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonalité</system:String>
  <system:String x:Key="dialogs.importproject.caption">Options d’importation</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Hanzi chinois → Pinyin</system:String>
