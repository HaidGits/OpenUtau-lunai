<!--Lunai overlay for uk-UA. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Створити гармонії...</system:String>

  <system:String x:Key="dialogs.about.close">Закрити</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Показано вбудований список учасників.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Нижче перелічені учасники оригінального репозиторію OpenUtau на GitHub. OpenUtau Lunai базується на їхній роботі. Дякуємо всім зі списку!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Завантаження списку учасників з GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Учасники</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Не вдалося завантажити список. Перевірте з’єднання з інтернетом і спробуйте знову.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Список учасників оновлено з GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai на GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau на GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau та OpenUtau Lunai — вільне програмне забезпечення з відкритим кодом за ліцензією MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Ви використовуєте OpenUtau Lunai — форк, створений, щоб зробити DiffSinger зручнішим і приємнішим у роботі. Класичні банки UTAU та всі інші типи голосових бібліотек, які вже підтримує OpenUtau, працюють як раніше. Також включено багато функцій із pull request’ів upstream, які ще не випущені або не злиті в оригінальний OpenUtau.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau — це відкрите середовище редагування для спільноти UTAU з сучасним інтерфейсом і розумною підтримкою фонетики. Відвідайте нас на Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau — відкрите середовище редагування для спільноти UTAU з сучасним інтерфейсом і розумною підтримкою фонетики.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Відкрити або імпортувати проєкт</system:String>
  <system:String x:Key="dialogs.dropproject.import">Імпортувати треки</system:String>
  <system:String x:Key="dialogs.dropproject.message">Відкрити перетягнутий файл як новий проєкт чи імпортувати його треки в поточний проєкт?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Відкрити проєкт</system:String>
  <system:String x:Key="dialogs.exportds.caption">Експорт скрипта DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Параметри variance</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Увімкніть кеш тензорів DiffSinger в налаштуваннях, щоб експортувати криві параметрів variance.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Створення гармоній</system:String>
  <system:String x:Key="dialogs.harmony.description">Створити нові треки гармоній на основі вибраної партії. Ноти транспонуються діатонічно в обраній тональності.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Для кожного вибраного голосу створюється новий трек під вихідним із транспонованими нотами. Виконавець і налаштування копіюються з вихідного треку.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Голоси гармонії</system:String>
  <system:String x:Key="dialogs.harmony.key">Тональність</system:String>
  <system:String x:Key="dialogs.importproject.caption">Параметри імпорту проєкту</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Китайські ієрогліфи → піньїнь</system:String>
  <system:String x:Key="dialogs.importproject.defaultlyric">Лірика за замовчуванням</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps">Заповнити короткі проміжки</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.threshold">Максимальна довжина для обробки (виключно)</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.thresholditem">1/{0} ноти</system:String>
  <system:String x:Key="dialogs.importproject.japanese">Японська лірика</system:String>
  <system:String x:Key="dialogs.importproject.japanese.hiragana">Ромадзі → хіраґана</system:String>
  <system:String x:Key="dialogs.importproject.japanese.none">Без перетворення</system:String>
  <system:String x:Key="dialogs.importproject.japanese.romaji">Хіраґана → ромадзі</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding">Відступ перед першою нотою</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding.size">Розмір відступу, якщо нота на початку кліпу</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping">Відповідність лірики (точна)</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping.hint">По рядку: звідки=куди</system:String>
  <system:String x:Key="dialogs.importproject.lyricsreplace">Заміна лірики</system:String>
  <system:String x:Key="dialogs.importproject.lyricsreplace.hint">звідки=&gt;куди або /шаблон/заміна/</system:String>
  <system:String x:Key="dialogs.importproject.lyricssection">Обробка лірики</system:String>
  <system:String x:Key="dialogs.importproject.message">Оберіть, що імпортувати з цього файлу:</system:String>
  <system:String x:Key="dialogs.importproject.notes">Ноти та лірика</system:String>
  <system:String x:Key="dialogs.importproject.pitch">Крива pitch (PITD)</system:String>
  <system:String x:Key="dialogs.importproject.resolveoverlaps">Виправити накладання нот</system:String>
  <system:String x:Key="dialogs.importproject.tempo">Маркери темпу</system:String>
  <system:String x:Key="dialogs.importproject.timesig">Розміри такту</system:String>
  <system:String x:Key="dialogs.messagebox.openlink">Відкрити сторінку завантаження</system:String>
  <system:String x:Key="dialogs.messagebox.openpackages">Менеджер пакетів</system:String>
  <system:String x:Key="dialogs.reportissue.discord.description">Зайдіть на сервер і опишіть помилку в #help. За потреби додайте лог через Довідка → Відкрити розташування логів.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Відкрити Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Скопіювати адресу</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Напишіть нам і за потреби додайте лог, якщо проблему складно відтворити.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">Ел. пошта</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Написати листа</system:String>
  <system:String x:Key="dialogs.reportissue.message">Опишіть, що пішло не так. Зручніше через Discord у каналі #help — так ми швидше відповімо; за потреби додайте лог. Можна також написати нам на пошту.</system:String>

