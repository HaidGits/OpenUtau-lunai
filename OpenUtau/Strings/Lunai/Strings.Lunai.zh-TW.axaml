<!--Lunai overlay for zh-TW. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">產生和聲...</system:String>

  <system:String x:Key="dialogs.about.close">關閉</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">正在顯示內嵌的貢獻者清單。</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">以下人員為 GitHub 上原始 OpenUtau 存放庫做出了貢獻。OpenUtau Lunai 建立在他們的成果之上。感謝所有列出的貢獻者！</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">正在從 GitHub 載入貢獻者...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">貢獻者</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">無法載入貢獻者。請檢查網路連線後再試一次。</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">已從 GitHub 更新貢獻者清單。</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">GitHub 上的 OpenUtau Lunai</system:String>
  <system:String x:Key="dialogs.about.github.upstream">GitHub 上的 OpenUtau</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau 與 OpenUtau Lunai 皆為採用 MIT 授權的免費開源軟體。</system:String>
  <system:String x:Key="dialogs.about.lunai.message">您正在執行 OpenUtau Lunai，這是一個旨在讓 DiffSinger 更易用、更愉快的分支。經典 UTAU 音源以及 OpenUtau 已支援的其他類型音源均可照常使用。此外還包含許多尚未發布或合併到原始 OpenUtau 的上游拉取請求中的功能。</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau 致力於成為面向 UTAU 社群的開源編輯環境，提供現代化的使用體驗與智慧音韻支援。歡迎造訪我們的 GitHub。</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau 致力於成為面向 UTAU 社群的開源編輯環境，提供現代化的使用體驗與智慧音韻支援。</system:String>
  <system:String x:Key="dialogs.dropproject.caption">開啟或匯入專案</system:String>
  <system:String x:Key="dialogs.dropproject.import">匯入音軌</system:String>
  <system:String x:Key="dialogs.dropproject.message">要開啟拖入的專案檔案，還是將其音軌匯入到目前專案？</system:String>
  <system:String x:Key="dialogs.dropproject.open">開啟專案</system:String>
  <system:String x:Key="dialogs.exportds.caption">匯出 DiffSinger 指令碼</system:String>
  <system:String x:Key="dialogs.exportds.variance">Variance 參數</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">請在偏好設定中啟用 DiffSinger 張量快取，以匯出 variance 參數曲線。</system:String>
  <system:String x:Key="dialogs.harmony.caption">產生和聲</system:String>
  <system:String x:Key="dialogs.harmony.description">根據所選段落建立新的和聲音軌。音符將依所選調性做自然音階移調。</system:String>
  <system:String x:Key="dialogs.harmony.hint">每個選取的聲部都會在來源音軌下方建立一條帶有移調音符的新音軌。歌手與設定會從來源音軌複製。</system:String>
  <system:String x:Key="dialogs.harmony.intervals">和聲聲部</system:String>
  <system:String x:Key="dialogs.harmony.key">調性</system:String>
  <system:String x:Key="dialogs.importproject.caption">匯入專案選項</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">漢字 → 拼音</system:String>
  <system:String x:Key="dialogs.importproject.defaultlyric">預設歌詞</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps">填補短空隙</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.threshold">最大處理長度（不含）</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.thresholditem">1/{0} 音符</system:String>
