  <system:String x:Key="dialogs.importproject.japanese.romaji">ひらがな → ローマ字</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding">最初のノート前の余白</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding.size">最初のノートがクリップ先頭から始まる場合の余白</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping">歌詞マッピング（完全一致）</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping.hint">1行につき1組：from=to</system:String>
