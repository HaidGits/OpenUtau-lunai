<!--Lunai overlay for ja-JP. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">ハーモニーを生成...</system:String>

  <system:String x:Key="dialogs.about.close">閉じる</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">埋め込みの貢献者リストを表示しています。</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">以下の方々は、GitHub上のオリジナル OpenUtau リポジトリに貢献されました。OpenUtau Lunai はその成果の上に成り立っています。皆様に感謝します！</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">GitHubから貢献者を読み込み中...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">貢献者</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">貢献者を読み込めませんでした。インターネット接続を確認して、もう一度お試しください。</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">貢献者リストをGitHubから更新しました。</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">GitHub上の OpenUtau Lunai</system:String>
  <system:String x:Key="dialogs.about.github.upstream">GitHub上の OpenUtau</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau および OpenUtau Lunai は、MITライセンスの無料オープンソースソフトウェアです。</system:String>
  <system:String x:Key="dialogs.about.lunai.message">お使いの環境は OpenUtau Lunai です。DiffSinger をより簡単に、快適に使えることを目指したフォークです。従来のUTAU音源や、OpenUtauがすでに対応している他のボイスバンク種別もこれまでどおり利用できます。また、オリジナルの OpenUtau にまだ未リリース・未マージの上流プルリクエスト由来の機能も多数含まれています。</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau は、UTAUコミュニティ向けのオープンソース編集環境を目指し、モダンな操作性といい音韻サポートを提供します。GitHubでご覧ください。</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau は、UTAUコミュニティ向けのオープンソース編集環境を目指し、モダンな操作性といい音韻サポートを提供します。</system:String>
  <system:String x:Key="dialogs.dropproject.caption">プロジェクトを開く / インポート</system:String>
  <system:String x:Key="dialogs.dropproject.import">トラックをインポート</system:String>
  <system:String x:Key="dialogs.dropproject.message">ドロップしたプロジェクトファイルを開きますか？それともトラックを現在のプロジェクトにインポートしますか？</system:String>
  <system:String x:Key="dialogs.dropproject.open">プロジェクトを開く</system:String>
  <system:String x:Key="dialogs.exportds.caption">DiffSingerスクリプトをエクスポート</system:String>
  <system:String x:Key="dialogs.exportds.variance">Varianceパラメータ</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Varianceパラメータ曲線をエクスポートするには、環境設定で DiffSinger テンソルキャッシュを有効にしてください。</system:String>
  <system:String x:Key="dialogs.harmony.caption">ハーモニーを生成</system:String>
  <system:String x:Key="dialogs.harmony.description">選択したパートから新しいハーモニートラックを作成します。ノートは指定したキーでダイアトニックに移調されます。</system:String>
  <system:String x:Key="dialogs.harmony.hint">選択した各ボイスは、ソースの下に移調済みノートの新しいトラックとして作成されます。シンガーと設定はソーストラックからコピーされます。</system:String>
  <system:String x:Key="dialogs.harmony.intervals">ハーモニーボイス</system:String>
  <system:String x:Key="dialogs.harmony.key">キー</system:String>
  <system:String x:Key="dialogs.importproject.caption">プロジェクトのインポートオプション</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">中国語漢字 → ピンイン</system:String>
  <system:String x:Key="dialogs.importproject.defaultlyric">デフォルト歌詞</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps">短いギャップを埋める</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.threshold">処理する最大長（未満）</system:String>
