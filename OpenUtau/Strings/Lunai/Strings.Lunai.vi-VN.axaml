  <system:String x:Key="dialogs.reportissue.discord.description">Tham gia máy chủ của chúng tôi và mô tả lỗi trong #help. Đính kèm nhật ký từ Trợ giúp → Mở vị trí nhật ký nếu cần.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Mở Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Sao chép địa chỉ</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Viết cho chúng tôi và đính kèm nhật ký nếu sự cố khó tái hiện.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">Email</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Viết email</system:String>
  <system:String x:Key="dialogs.reportissue.message">Hãy cho chúng tôi biết vấn đề. Nên dùng Discord #help để chúng tôi phản hồi nhanh; đính kèm tệp nhật ký khi hữu ích. Bạn cũng có thể gửi email.</system:String>

