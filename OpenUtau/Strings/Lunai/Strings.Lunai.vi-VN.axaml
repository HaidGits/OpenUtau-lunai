<!--Lunai overlay for vi-VN. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Tạo hòa âm...</system:String>

  <system:String x:Key="dialogs.about.close">Đóng</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Đang hiển thị danh sách người đóng góp được nhúng.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Những người này đã đóng góp cho kho OpenUtau gốc trên GitHub. OpenUtau Lunai được xây dựng dựa trên công việc của họ. Cảm ơn tất cả mọi người trong danh sách!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Đang tải người đóng góp từ GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Người đóng góp</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Không thể tải danh sách người đóng góp. Kiểm tra kết nối internet và thử lại.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Danh sách người đóng góp đã được cập nhật từ GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai trên GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau trên GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau và OpenUtau Lunai là phần mềm mã nguồn mở miễn phí theo giấy phép MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Bạn đang chạy OpenUtau Lunai, một bản fork nhằm giúp DiffSinger dễ dùng và thú vị hơn. Các bank UTAU cổ điển và mọi loại thư viện giọng mà OpenUtau đã hỗ trợ vẫn hoạt động bình thường. Đồng thời bao gồm nhiều tính năng từ các pull request gốc chưa được phát hành hoặc hợp nhất vào OpenUtau gốc.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau hướng tới trở thành môi trường chỉnh sửa mã nguồn mở cho cộng đồng UTAU, với trải nghiệm hiện đại và hỗ trợ ngữ âm thông minh. Hãy ghé thăm chúng tôi trên Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau hướng tới trở thành môi trường chỉnh sửa mã nguồn mở cho cộng đồng UTAU, với trải nghiệm hiện đại và hỗ trợ ngữ âm thông minh.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Mở hoặc nhập dự án</system:String>
  <system:String x:Key="dialogs.dropproject.import">Nhập track</system:String>
  <system:String x:Key="dialogs.dropproject.message">Bạn muốn mở tệp dự án vừa thả vào, hay nhập các track của nó vào dự án hiện tại?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Mở dự án</system:String>
  <system:String x:Key="dialogs.exportds.caption">Xuất script DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Tham số variance</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Bật bộ nhớ đệm tensor DiffSinger trong Tùy chọn để xuất đường cong tham số variance.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Tạo hòa âm</system:String>
  <system:String x:Key="dialogs.harmony.description">Tạo các track hòa âm mới từ phần đã chọn. Nốt được chuyển giọng theo điệu thức trong giọng đã chọn.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Mỗi giọng đã chọn tạo một track mới bên dưới nguồn với các nốt đã chuyển giọng. Ca sĩ và cài đặt được sao chép từ track nguồn.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Giọng hòa âm</system:String>
  <system:String x:Key="dialogs.harmony.key">Giọng</system:String>
  <system:String x:Key="dialogs.importproject.caption">Tùy chọn nhập dự án</system:String>
