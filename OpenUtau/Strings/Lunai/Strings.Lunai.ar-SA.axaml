<!--Lunai overlay for ar-SA. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">إنشاء توافقيات...</system:String>

  <system:String x:Key="dialogs.about.close">إغلاق</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">يتم عرض قائمة المساهمين المضمّنة.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">ساهم هؤلاء الأشخاص في مستودع OpenUtau الأصلي على GitHub. يعتمد OpenUtau Lunai على عملهم. شكرًا لكل من ورد اسمه في القائمة!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">جارٍ تحميل المساهمين من GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">المساهمون</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">تعذّر تحميل المساهمين. تحقق من اتصال الإنترنت ثم حاول مجددًا.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">تم تحديث قائمة المساهمين من GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai على GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau على GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau وOpenUtau Lunai برمجيات حرة مفتوحة المصدر بموجب رخصة MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">أنت تستخدم OpenUtau Lunai، وهو فرع يهدف إلى جعل DiffSinger أسهل وأكثر متعة في الاستخدام. بنوك UTAU الكلاسيكية وجميع أنواع مكتبات الصوت الأخرى التي يدعمها OpenUtau بالفعل ما زالت تعمل كالمعتاد. ويتضمن أيضًا العديد من الميزات من طلبات السحب في المشروع الأصلي التي لم تُصدَر أو تُدمَج بعد في OpenUtau الأصلي.</system:String>
  <system:String x:Key="dialogs.about.message">يهدف OpenUtau إلى أن يكون بيئة تحرير مفتوحة المصدر لمجتمع UTAU، بتجربة مستخدم حديثة ودعم صوتي ذكي. زرنا على Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">يهدف OpenUtau إلى أن يكون بيئة تحرير مفتوحة المصدر لمجتمع UTAU، بتجربة مستخدم حديثة ودعم صوتي ذكي.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">فتح المشروع أو استيراده</system:String>
  <system:String x:Key="dialogs.dropproject.import">استيراد المسارات</system:String>
  <system:String x:Key="dialogs.dropproject.message">هل تريد فتح ملف المشروع المُسقَط، أم استيراد مساراته إلى المشروع الحالي؟</system:String>
  <system:String x:Key="dialogs.dropproject.open">فتح المشروع</system:String>
  <system:String x:Key="dialogs.exportds.caption">تصدير سكربت DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">معلمات التباين (Variance)</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">فعّل ذاكرة التخزين المؤقت لمصفوفات DiffSinger في التفضيلات لتصدير منحنيات معلمات التباين.</system:String>
  <system:String x:Key="dialogs.harmony.caption">إنشاء التوافقيات</system:String>
  <system:String x:Key="dialogs.harmony.description">إنشاء مسارات توافقية جديدة من الجزء المحدد. تُنقَل النغمات دياتونيًا ضمن المفتاح المختار.</system:String>
  <system:String x:Key="dialogs.harmony.hint">كل صوت محدد ينشئ مسارًا جديدًا أسفل المصدر المصدر بنغمات منقولة. يُنسَخ المغني والإعدادات من مسار المصدر.</system:String>
