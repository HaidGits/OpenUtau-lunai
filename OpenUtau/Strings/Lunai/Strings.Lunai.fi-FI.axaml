<!--Lunai overlay for fi-FI. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Luo harmonioita...</system:String>

  <system:String x:Key="dialogs.about.close">Sulje</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Näytetään sisäänrakennettu tekijäluettelo.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Nämä henkilöt ovat osallistuneet alkuperäiseen OpenUtau-repositorioon GitHubissa. OpenUtau Lunai rakentuu heidän työnsä varaan. Kiitos kaikille listatuille!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Ladataan tekijöitä GitHubista...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Tekijät</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Tekijöitä ei voitu ladata. Tarkista internetyhteys ja yritä uudelleen.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Tekijäluettelo päivitetty GitHubista.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai GitHubissa</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau GitHubissa</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau ja OpenUtau Lunai ovat ilmaisia avoimen lähdekoodin ohjelmistoja MIT-lisenssillä.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Käytät OpenUtau Lunaita, haarautumaa, jonka tavoitteena on tehdä DiffSingeristä helpompi ja miellyttävämpi käyttää. Klassiset UTAU-pankit ja kaikki muut OpenUtaun jo tukemat äänipankkityypit toimivat edelleen normaalisti. Mukana on myös monia ominaisuuksia upstream-pull requesteista, joita ei ole vielä julkaistu tai yhdistetty alkuperäiseen OpenUtauhun.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau pyrkii olemaan avoimen lähdekoodin editointiympäristö UTAU-yhteisölle, modernilla käyttökokemuksella ja älykkäällä fonologisella tuella. Vieraile meillä Githubissa.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau pyrkii olemaan avoimen lähdekoodin editointiympäristö UTAU-yhteisölle, modernilla käyttökokemuksella ja älykkäällä fonologisella tuella.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Avaa tai tuo projekti</system:String>
  <system:String x:Key="dialogs.dropproject.import">Tuo raidat</system:String>
  <system:String x:Key="dialogs.dropproject.message">Haluatko avata pudotetun projektitiedoston vai tuoda sen raidat nykyiseen projektiin?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Avaa projekti</system:String>
  <system:String x:Key="dialogs.exportds.caption">Vie DiffSinger-skripti</system:String>
  <system:String x:Key="dialogs.exportds.variance">Varianssiparametrit</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Ota DiffSinger-tensorivälimuisti käyttöön Asetuksissa viedäksesi varianssiparametrikäyrät.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Luo harmoniat</system:String>
  <system:String x:Key="dialogs.harmony.description">Luo uusia harmoniaraidat valitusta osasta. Nuotit transponoidaan diatonisesti valitussa sävellajissa.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Jokainen valittu ääni luo uuden raidan lähteen alle transponoiduilla nuoteilla. Laulaja ja asetukset kopioidaan lähderaidasta.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Harmoniaäänet</system:String>
  <system:String x:Key="dialogs.harmony.key">Sävellaji</system:String>
  <system:String x:Key="dialogs.importproject.caption">Projektin tuontiasetukset</system:String>
