  <system:String x:Key="dialogs.reportissue.email.copy">Kopioi osoite</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Kirjoita meille ja liitä loki, jos ongelmaa on vaikea toistaa.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">Sähköposti</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Kirjoita sähköposti</system:String>
  <system:String x:Key="dialogs.reportissue.message">Kerro, mikä meni pieleen. Suosi Discordia #help, jotta voimme vastata nopeasti; liitä lokitiedosto tarvittaessa. Voit myös lähettää sähköpostia.</system:String>

