<!--Lunai overlay for pl-PL. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Generuj harmonie...</system:String>

  <system:String x:Key="dialogs.about.close">Zamknij</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Wyświetlana jest wbudowana lista współtwórców.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Te osoby przyczyniły się do rozwoju oryginalnego repozytorium OpenUtau na GitHub. OpenUtau Lunai opiera się na ich pracy. Dziękujemy wszystkim wymienionym!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Wczytywanie współtwórców z GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Współtwórcy</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Nie można wczytać współtwórców. Sprawdź połączenie z Internetem i spróbuj ponownie.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Lista współtwórców została zaktualizowana z GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai na GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau na GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau i OpenUtau Lunai to bezpłatne oprogramowanie open source na licencji MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Używasz OpenUtau Lunai, forka mającego ułatwić i uprzyjemnić pracę z DiffSinger. Klasyczne banki UTAU oraz wszystkie inne typy banków głosowych obsługiwane już przez OpenUtau nadal działają jak zwykle. Zawiera on również wiele funkcji z nadrzędnych pull requestów, które nie zostały jeszcze wydane ani scalone z oryginalnym OpenUtau.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau ma być środowiskiem edycji open source dla społeczności UTAU, oferującym nowoczesne wrażenia użytkownika i inteligentną obsługę fonologiczną. Odwiedź nas na GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau ma być środowiskiem edycji open source dla społeczności UTAU, oferującym nowoczesne wrażenia użytkownika i inteligentną obsługę fonologiczną.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Otwórz or import projekt</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importuj ścieżki</system:String>
  <system:String x:Key="dialogs.dropproject.message">Czy chcesz otworzyć upuszczony plik projektu, czy zaimportować jego ścieżki do bieżącego projektu?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Otwórz projekt</system:String>
  <system:String x:Key="dialogs.exportds.caption">Eksportuj DiffSinger skrypt</system:String>
  <system:String x:Key="dialogs.exportds.variance">Wariancja parametry</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Włącz pamięć podręczną tensorów DiffSinger w Preferencjach, aby eksportować krzywe parametrów wariancji.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Generate Harmonie</system:String>
  <system:String x:Key="dialogs.harmony.description">Utwórz nowe ścieżki harmonii z wybranej części. Nuty są transponowane diatonicznie w wybranej tonacji.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Każdy wybrany głos tworzy nową ścieżkę pod źródłową z transponowanymi nutami. Wokalista i ustawienia są kopiowane ze ścieżki źródłowej.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Głosy harmonii</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonacja</system:String>
  <system:String x:Key="dialogs.importproject.caption">Importuj projekt options</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Chińskie hanzi → Pinyin</system:String>
  <system:String x:Key="dialogs.importproject.defaultlyric">Domyślny tekst</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps">Wypełnij krótkie przerwy</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps.threshold">Maksymalna przetwarzana długość (wyłącznie)</system:String>
