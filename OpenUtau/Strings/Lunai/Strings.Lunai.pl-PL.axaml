  <system:String x:Key="dialogs.importproject.pitch">Krzywa wysokości (PITD)</system:String>
  <system:String x:Key="dialogs.importproject.resolveoverlaps">Napraw nakładające się nuty</system:String>
  <system:String x:Key="dialogs.importproject.tempo">Znaczniki tempa</system:String>
  <system:String x:Key="dialogs.importproject.timesig">Metrum</system:String>
  <system:String x:Key="dialogs.messagebox.openlink">Otwórz stronę pobierania</system:String>
  <system:String x:Key="dialogs.messagebox.openpackages">Menedżer pakietów</system:String>
  <system:String x:Key="dialogs.reportissue.discord.description">Dołącz do naszego serwera i opisz błąd na #help. W razie potrzeby dołącz log z Pomoc → Otwórz lokalizację logów.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Otwórz Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Kopiuj adres</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Napisz do nas i dołącz log, jeśli problem jest trudny do odtworzenia.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Napisz e-mail</system:String>
  <system:String x:Key="dialogs.reportissue.message">Opisz, co poszło nie tak. Preferujemy Discord #help, aby szybko odpowiedzieć; dołącz plik logu, jeśli pomoże. Możesz też napisać do nas e-mail.</system:String>

