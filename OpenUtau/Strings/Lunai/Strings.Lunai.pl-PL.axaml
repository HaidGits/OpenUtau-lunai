  <system:String x:Key="dialogs.importproject.japanese.romaji">Hiragana → Romaji</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding">Odstęp przed pierwszą nutą</system:String>
  <system:String x:Key="dialogs.importproject.leadingpadding.size">Odstęp, gdy pierwsza nuta zaczyna się na początku klipu</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping">Mapowanie tekstu (dokładne)</system:String>
  <system:String x:Key="dialogs.importproject.lyricsmapping.hint">Po jednym w wierszu: z=na</system:String>
