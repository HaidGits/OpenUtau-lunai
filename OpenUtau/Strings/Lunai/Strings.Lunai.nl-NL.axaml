<!--Lunai overlay for nl-NL. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Harmonieën genereren...</system:String>

  <system:String x:Key="dialogs.about.close">Sluiten</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">De ingebouwde lijst met bijdragers wordt weergegeven.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Deze mensen hebben bijgedragen aan de oorspronkelijke OpenUtau-repository op GitHub. OpenUtau Lunai bouwt voort op hun werk. Dank aan iedereen die hier wordt vermeld!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Bijdragers worden geladen van GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Bijdragers</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">De bijdragers konden niet worden geladen. Controleer uw internetverbinding en probeer het opnieuw.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Lijst met bijdragers bijgewerkt vanaf GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai op GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau op GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau en OpenUtau Lunai zijn vrije opensourcesoftware onder de MIT-licentie.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">U gebruikt OpenUtau Lunai, een fork die DiffSinger eenvoudiger en prettiger in gebruik maakt. Klassieke UTAU-banken en alle andere voicebanktypen die OpenUtau al ondersteunt, werken gewoon zoals altijd. Ook bevat het veel functies uit upstream-pullrequests die nog niet zijn uitgebracht of samengevoegd met het oorspronkelijke OpenUtau.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau wil een opensourcebewerkingsomgeving zijn voor de UTAU-gemeenschap, met een moderne gebruikerservaring en intelligente fonologische ondersteuning. Bezoek ons op GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau wil een opensourcebewerkingsomgeving zijn voor de UTAU-gemeenschap, met een moderne gebruikerservaring en intelligente fonologische ondersteuning.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Openen or import project</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importeren sporen</system:String>
  <system:String x:Key="dialogs.dropproject.message">Wilt u het neergezette projectbestand openen of de sporen ervan in het huidige project importeren?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Openen project</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exporteren DiffSinger script</system:String>
