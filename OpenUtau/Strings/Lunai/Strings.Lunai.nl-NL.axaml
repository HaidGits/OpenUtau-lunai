  <system:String x:Key="dialogs.reportissue.email.description">Schrijf ons en voeg een logbestand toe als het probleem moeilijk te reproduceren is.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">E-mail schrijven</system:String>
  <system:String x:Key="dialogs.reportissue.message">Vertel ons wat er misging. Gebruik bij voorkeur Discord #help zodat we snel kunnen reageren; voeg een logbestand toe als dat helpt. U kunt ons ook e-mailen.</system:String>

