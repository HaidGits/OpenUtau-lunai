  <system:String x:Key="dialogs.messagebox.openpackages">Administrador de paquetes</system:String>
  <system:String x:Key="dialogs.reportissue.discord.description">Únete a nuestro servidor y describe el error en #help. Adjunta un registro desde Ayuda → Abrir ubicación de registros si es necesario.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Abrir Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Copiar dirección</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Escríbenos y adjunta un registro si el problema es difícil de reproducir.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">Correo electrónico</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Escribir correo electrónico</system:String>
  <system:String x:Key="dialogs.reportissue.message">Cuéntanos qué ha fallado. Usa preferentemente Discord #help para que podamos responder rápido; incluye un archivo de registro cuando sea útil. También puedes escribirnos por correo.</system:String>

