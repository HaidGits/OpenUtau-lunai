<!--Lunai overlay for es-ES. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Generar armonías...</system:String>

  <system:String x:Key="dialogs.about.close">Cerrar</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Mostrando la lista de colaboradores integrada.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Estas personas contribuyeron al repositorio original de OpenUtau en GitHub. OpenUtau Lunai se basa en su trabajo. ¡Gracias a todas las personas de la lista!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Cargando colaboradores desde GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Colaboradores</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">No se pudieron cargar los colaboradores. Comprueba tu conexión a Internet e inténtalo de nuevo.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Lista de colaboradores actualizada desde GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai en GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau en GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau y OpenUtau Lunai son software libre y de código abierto bajo la licencia MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Estás usando OpenUtau Lunai, un fork pensado para hacer que DiffSinger sea más fácil y agradable de usar. Los bancos UTAU clásicos y todos los demás tipos de bancos de voz compatibles con OpenUtau siguen funcionando como siempre. También incluye muchas funciones de solicitudes de extracción del proyecto original que aún no se han publicado ni integrado en OpenUtau original.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau aspira a ser un entorno de edición de código abierto para la comunidad UTAU, con una experiencia de usuario moderna y asistencia fonológica inteligente. Visítanos en GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau aspira a ser un entorno de edición de código abierto para la comunidad UTAU, con una experiencia de usuario moderna y asistencia fonológica inteligente.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Abrir o importar proyecto</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importar pistas</system:String>
  <system:String x:Key="dialogs.dropproject.message">¿Quieres abrir el archivo de proyecto soltado o importar sus pistas al proyecto actual?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Abrir proyecto</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exportar script de DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Parámetros de variación</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Activa la caché de tensores de DiffSinger en Preferencias para exportar curvas de parámetros de variación.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Generar armonías</system:String>
  <system:String x:Key="dialogs.harmony.description">Crea nuevas pistas de armonía a partir de la parte seleccionada. Las notas se transponen diatónicamente en la tonalidad elegida.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Cada voz seleccionada crea una pista nueva bajo la pista de origen con notas transpuestas. El cantante y los ajustes se copian de la pista de origen.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Voces de armonía</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonalidad</system:String>
  <system:String x:Key="dialogs.importproject.caption">Opciones de importación</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Hanzi chino → pinyin</system:String>
  <system:String x:Key="dialogs.importproject.defaultlyric">Letra predeterminada</system:String>
  <system:String x:Key="dialogs.importproject.fillgaps">Rellenar huecos cortos</system:String>
