  <system:String x:Key="dialogs.reportissue.email.copy">Adresse kopieren</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Schreibe uns und hänge ein Log an, wenn sich das Problem schwer reproduzieren lässt.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-Mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">E-Mail schreiben</system:String>
  <system:String x:Key="dialogs.reportissue.message">Beschreibe, was schiefgelaufen ist. Am besten über Discord #help, damit wir schnell antworten können; füge bei Bedarf eine Logdatei bei. Du kannst uns auch eine E-Mail senden.</system:String>

