<!--Lunai overlay for de-DE. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Harmonien erzeugen...</system:String>

  <system:String x:Key="dialogs.about.close">Schließen</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Eingebettete Mitwirkendenliste wird angezeigt.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Diese Personen haben zum ursprünglichen OpenUtau-Repository auf GitHub beigetragen. OpenUtau Lunai baut auf ihrer Arbeit auf. Vielen Dank an alle Genannten!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Mitwirkende werden von GitHub geladen...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Mitwirkende</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Mitwirkende konnten nicht geladen werden. Prüfe deine Internetverbindung und versuche es erneut.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Mitwirkendenliste von GitHub aktualisiert.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai auf GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau auf GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau und OpenUtau Lunai sind freie Open-Source-Software unter der MIT-Lizenz.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Du verwendest OpenUtau Lunai, einen Fork, der DiffSinger einfacher und angenehmer machen soll. Klassische UTAU-Banks und alle anderen von OpenUtau bereits unterstützten Voicebank-Typen funktionieren weiterhin wie gewohnt. Enthalten sind außerdem viele Funktionen aus Upstream-Pull-Requests, die noch nicht veröffentlicht oder in das originale OpenUtau übernommen wurden.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau soll eine Open-Source-Editing-Umgebung für die UTAU-Community sein – mit modernem Nutzungserlebnis und intelligenter phonologischer Unterstützung. Besuche uns auf Github.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau soll eine Open-Source-Editing-Umgebung für die UTAU-Community sein – mit modernem Nutzungserlebnis und intelligenter phonologischer Unterstützung.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Projekt öffnen oder importieren</system:String>
  <system:String x:Key="dialogs.dropproject.import">Spuren importieren</system:String>
  <system:String x:Key="dialogs.dropproject.message">Möchtest du die abgelegte Projektdatei öffnen oder ihre Spuren in das aktuelle Projekt importieren?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Projekt öffnen</system:String>
  <system:String x:Key="dialogs.exportds.caption">DiffSinger-Skript exportieren</system:String>
  <system:String x:Key="dialogs.exportds.variance">Varianzparameter</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Aktiviere den DiffSinger-Tensor-Cache in den Einstellungen, um Varianzparameterkurven zu exportieren.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Harmonien erzeugen</system:String>
  <system:String x:Key="dialogs.harmony.description">Erzeugt neue Harmoniespuren aus dem ausgewählten Part. Noten werden diatonisch in der gewählten Tonart transponiert.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Jede ausgewählte Stimme erzeugt unter der Quelle eine neue Spur mit transponierten Noten. Sänger und Einstellungen werden von der Quellspur übernommen.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Harmoniestimmen</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonart</system:String>
  <system:String x:Key="dialogs.importproject.caption">Importoptionen</system:String>
