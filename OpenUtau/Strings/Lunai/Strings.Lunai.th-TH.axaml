<!--Lunai overlay for th-TH. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">สร้างเสียงประสาน...</system:String>

  <system:String x:Key="dialogs.about.close">ปิด</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">กำลังแสดงรายชื่อผู้ร่วมพัฒนาแบบฝังตัว</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">บุคคลเหล่านี้มีส่วนร่วมในที่เก็บ OpenUtau ต้นทางบน GitHub. OpenUtau Lunai สร้างต่อจากผลงานของพวกเขา ขอขอบคุณทุกคนในรายชื่อ!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">กำลังโหลดผู้ร่วมพัฒนาจาก GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">ผู้ร่วมพัฒนา</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">โหลดรายชื่อผู้ร่วมพัฒนาไม่สำเร็จ โปรดตรวจสอบการเชื่อมต่ออินเทอร์เน็ตแล้วลองอีกครั้ง</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">อัปเดตรายชื่อผู้ร่วมพัฒนาจาก GitHub แล้ว</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai บน GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau บน GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau และ OpenUtau Lunai เป็นซอฟต์แวร์โอเพนซอร์สฟรีภายใต้สัญญาอนุญาต MIT</system:String>
  <system:String x:Key="dialogs.about.lunai.message">คุณกำลังใช้ OpenUtau Lunai ซึ่งเป็นฟอร์กที่มุ่งให้ DiffSinger ใช้งานง่ายและสนุกยิ่งขึ้น แบงก์ UTAU คลาสสิกและประเภทไลบรารีเสียงอื่นทั้งหมดที่ OpenUtau รองรับอยู่แล้วยังใช้งานได้ตามปกติ นอกจากนี้ยังรวมฟีเจอร์จำนวนมากจากพูลรีเควสต์ต้นทางที่ยังไม่ได้เผยแพร่หรือรวมเข้า OpenUtau ต้นฉบับ</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau มุ่งเป็นสภาพแวดล้อมแก้ไขโอเพนซอร์สสำหรับชุมชน UTAU พร้อมประสบการณ์ใช้งานที่ทันสมัยและการรองรับสัทศาสตร์อย่างชาญฉลาด เยี่ยมชมเราได้บน Github</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau มุ่งเป็นสภาพแวดล้อมแก้ไขโอเพนซอร์สสำหรับชุมชน UTAU พร้อมประสบการณ์ใช้งานที่ทันสมัยและการรองรับสัทศาสตร์อย่างชาญฉลาด</system:String>
  <system:String x:Key="dialogs.dropproject.caption">เปิดหรือนำเข้าโปรเจกต์</system:String>
  <system:String x:Key="dialogs.dropproject.import">นำเข้าแทร็ก</system:String>
  <system:String x:Key="dialogs.dropproject.message">ต้องการเปิดไฟล์โปรเจกต์ที่วางไว้ หรือนำเข้าแทร็กเข้าโปรเจกต์ปัจจุบัน?</system:String>
  <system:String x:Key="dialogs.dropproject.open">เปิดโปรเจกต์</system:String>
  <system:String x:Key="dialogs.exportds.caption">ส่งออกสคริปต์ DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">พารามิเตอร์ความแปรปรวน</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">เปิดใช้งานแคชเทนเซอร์ DiffSinger ในการตั้งค่าเพื่อส่งออกเส้นโค้งพารามิเตอร์ความแปรปรวน</system:String>
  <system:String x:Key="dialogs.harmony.caption">สร้างเสียงประสาน</system:String>
  <system:String x:Key="dialogs.harmony.description">สร้างแทร็กเสียงประสานใหม่จากพาร์ทที่เลือก โน้ตจะถูกทรานสโพสแบบไดอะโทนิกในคีย์ที่เลือก</system:String>
  <system:String x:Key="dialogs.harmony.hint">แต่ละเสียงที่เลือกจะสร้างแทร็กใหม่ใต้ต้นทางพร้อมโน้ตที่ทรานสโพสแล้ว นักร้องและการตั้งค่าจะถูกคัดลอกจากแทร็กต้นทาง</system:String>
  <system:String x:Key="dialogs.harmony.intervals">เสียงประสาน</system:String>
  <system:String x:Key="dialogs.harmony.key">คีย์</system:String>
  <system:String x:Key="dialogs.importproject.caption">ตัวเลือกการนำเข้าโปรเจกต์</system:String>
