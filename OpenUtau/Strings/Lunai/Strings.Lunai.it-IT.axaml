  <system:String x:Key="dialogs.reportissue.discord.description">Unisciti al nostro server e descrivi il bug in #help. Se necessario, allega un log da Aiuto → Apri posizione dei log.</system:String>
  <system:String x:Key="dialogs.reportissue.discord.open">Apri Discord</system:String>
  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Copia indirizzo</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Scrivici e allega un log se il problema è difficile da riprodurre.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Scrivi email</system:String>
  <system:String x:Key="dialogs.reportissue.message">Spiegaci cosa è andato storto. Preferisci Discord #help così possiamo risponderti rapidamente; includi un file di log quando utile. Puoi anche scriverci via email.</system:String>

