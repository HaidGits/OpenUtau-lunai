<!--Lunai overlay for it-IT. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Genera armonie...</system:String>

  <system:String x:Key="dialogs.about.close">Chiudi</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Viene mostrato l'elenco incorporato dei collaboratori.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Queste persone hanno contribuito al repository originale di OpenUtau su GitHub. OpenUtau Lunai si basa sul loro lavoro. Grazie a tutti i presenti nell'elenco!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Caricamento dei collaboratori da GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Collaboratori</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Impossibile caricare i collaboratori. Controlla la connessione Internet e riprova.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Elenco dei collaboratori aggiornato da GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai su GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau su GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau e OpenUtau Lunai sono software gratuiti e open source con licenza MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Stai usando OpenUtau Lunai, un fork pensato per rendere DiffSinger più semplice e piacevole da usare. Le banche vocali UTAU classiche e tutti gli altri tipi di voicebank già supportati da OpenUtau continuano a funzionare normalmente. Include inoltre molte funzionalità da pull request upstream non ancora rilasciate o integrate nell'OpenUtau originale.</system:String>
  <system:String x:Key="dialogs.about.message">OpenUtau punta a essere un ambiente di editing open source per la comunità UTAU, con un'esperienza utente moderna e supporto fonologico intelligente. Visitaci su GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">OpenUtau punta a essere un ambiente di editing open source per la comunità UTAU, con un'esperienza utente moderna e supporto fonologico intelligente.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Apri o importa progetto</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importa tracce</system:String>
  <system:String x:Key="dialogs.dropproject.message">Vuoi aprire il file di progetto rilasciato oppure importarene le tracce nel progetto corrente?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Apri progetto</system:String>
  <system:String x:Key="dialogs.exportds.caption">Esporta script DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Parametri di varianza</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Abilita la cache tensoriale DiffSinger nelle Preferenze per esportare le curve dei parametri di varianza.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Genera armonie</system:String>
  <system:String x:Key="dialogs.harmony.description">Crea nuove tracce di armonia dalla parte selezionata. Le note vengono trasposte diatonicamente nella tonalità scelta.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Ogni voce selezionata crea una nuova traccia sotto quella sorgente con note trasposte. Cantante e impostazioni vengono copiati dalla traccia sorgente.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Voci dell'armonia</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonalità</system:String>
  <system:String x:Key="dialogs.importproject.caption">Opzioni di importazione del progetto</system:String>
  <system:String x:Key="dialogs.importproject.chinesepinyin">Hanzi cinesi → Pinyin</system:String>
