  <system:String x:Key="dialogs.reportissue.discord.title">Discord</system:String>
  <system:String x:Key="dialogs.reportissue.email.address">lunaiproject@gmail.com</system:String>
  <system:String x:Key="dialogs.reportissue.email.copy">Copiar endereço</system:String>
  <system:String x:Key="dialogs.reportissue.email.description">Escreva para nós e anexe um log se o problema for difícil de reproduzir.</system:String>
  <system:String x:Key="dialogs.reportissue.email.title">E-mail</system:String>
  <system:String x:Key="dialogs.reportissue.email.write">Escrever e-mail</system:String>
  <system:String x:Key="dialogs.reportissue.message">Conte-nos o que deu errado. Prefira o Discord #help para podermos responder rapidamente; inclua um arquivo de log quando ajudar. Você também pode enviar um e-mail.</system:String>

