<!--Lunai overlay for pt-BR. Not managed by Crowdin.-->
<!--Professional UI translation of Lunai-only strings.-->
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:system="clr-namespace:System;assembly=mscorlib"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <system:String x:Key="context.part.generateharmonies">Gerar harmonias...</system:String>

  <system:String x:Key="dialogs.about.close">Fechar</system:String>
  <system:String x:Key="dialogs.about.contributors.embedded">Exibindo a lista incorporada de colaboradores.</system:String>
  <system:String x:Key="dialogs.about.contributors.intro">Estas pessoas contribuíram para o repositório original do OpenUtau no GitHub. O OpenUtau Lunai se baseia no trabalho delas. Agradecemos a todas as pessoas listadas!</system:String>
  <system:String x:Key="dialogs.about.contributors.loading">Carregando colaboradores do GitHub...</system:String>
  <system:String x:Key="dialogs.about.contributors.title">Colaboradores</system:String>
  <system:String x:Key="dialogs.about.contributors.unavailable">Não foi possível carregar os colaboradores. Verifique sua conexão com a Internet e tente novamente.</system:String>
  <system:String x:Key="dialogs.about.contributors.updated">Lista de colaboradores atualizada do GitHub.</system:String>
  <system:String x:Key="dialogs.about.contributors.upstream">OpenUtau ({0})</system:String>
  <system:String x:Key="dialogs.about.github.lunai">OpenUtau Lunai no GitHub</system:String>
  <system:String x:Key="dialogs.about.github.upstream">OpenUtau no GitHub</system:String>
  <system:String x:Key="dialogs.about.license">OpenUtau e OpenUtau Lunai são softwares livres e de código aberto sob a licença MIT.</system:String>
  <system:String x:Key="dialogs.about.lunai.message">Você está executando o OpenUtau Lunai, um fork voltado a tornar o DiffSinger mais fácil e agradável de usar. Bancos de voz UTAU clássicos e todos os outros tipos de voicebank já compatíveis com o OpenUtau continuam funcionando normalmente. Ele também inclui muitos recursos de pull requests upstream que ainda não foram lançados ou integrados ao OpenUtau original.</system:String>
  <system:String x:Key="dialogs.about.message">O OpenUtau busca ser um ambiente de edição de código aberto para a comunidade UTAU, com experiência de usuário moderna e suporte fonológico inteligente. Visite-nos no GitHub.</system:String>
  <system:String x:Key="dialogs.about.upstream.message">O OpenUtau busca ser um ambiente de edição de código aberto para a comunidade UTAU, com experiência de usuário moderna e suporte fonológico inteligente.</system:String>
  <system:String x:Key="dialogs.dropproject.caption">Abrir ou importar projeto</system:String>
  <system:String x:Key="dialogs.dropproject.import">Importar faixas</system:String>
  <system:String x:Key="dialogs.dropproject.message">Deseja abrir o arquivo de projeto solto ou importar suas faixas para o projeto atual?</system:String>
  <system:String x:Key="dialogs.dropproject.open">Abrir projeto</system:String>
  <system:String x:Key="dialogs.exportds.caption">Exportar script do DiffSinger</system:String>
  <system:String x:Key="dialogs.exportds.variance">Parâmetros de variância</system:String>
  <system:String x:Key="dialogs.exportds.variance.hint">Ative o cache de tensores do DiffSinger nas Preferências para exportar curvas de parâmetros de variância.</system:String>
  <system:String x:Key="dialogs.harmony.caption">Gerar harmonias</system:String>
  <system:String x:Key="dialogs.harmony.description">Crie novas faixas de harmonia a partir da parte selecionada. As notas são transpostas diatonicamente na tonalidade escolhida.</system:String>
  <system:String x:Key="dialogs.harmony.hint">Cada voz selecionada cria uma nova faixa abaixo da fonte com notas transpostas. O cantor e as configurações são copiados da faixa de origem.</system:String>
  <system:String x:Key="dialogs.harmony.intervals">Vozes de harmonia</system:String>
  <system:String x:Key="dialogs.harmony.key">Tonalidade</system:String>
  <system:String x:Key="dialogs.importproject.caption">Opções de importação de projeto</system:String>
