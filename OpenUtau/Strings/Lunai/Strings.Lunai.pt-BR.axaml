  <system:String x:Key="dialogs.messagebox.openpackages">Gerenciador de pacotes</system:String>
  <system:String x:Key="dialogs.reportissue.discord.description">Entre no nosso servidor e descreva o erro em #help. Anexe um log em Ajuda → Abrir local dos logs, se necessário.</system:String>
